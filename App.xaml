<Application x:Class="LearnXaml.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LearnXaml.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:RgbToColorConverter x:Key="RgbToColorConverter" />
            <conv:AgeToColorConverter x:Key="AgeToColorConverter" />
            <conv:PriceToBackgroundConverter x:Key="PriceToBackgroundConverter" />
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>