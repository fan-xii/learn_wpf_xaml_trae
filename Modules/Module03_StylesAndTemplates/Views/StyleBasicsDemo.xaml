<Page x:Class="LearnXaml.Modules.Module03_StylesAndTemplates.Views.StyleBasicsDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module03_StylesAndTemplates.Views"
      Title="样式基础">
    <Page.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#F44336" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C62828" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#4CAF50" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2E7D32" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InfoTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderBrush" Value="#BDBDBD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StyledTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#424242" />
            <Setter Property="Margin" Value="0,4" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📝 样式基础 (Style Basics)" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="💡 什么是样式 (Style)？" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="样式是一组属性值的集合，可以统一应用到多个元素上，实现 UI 外观的一致性和可维护性。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="样式可以定义在：元素级别（内联）、容器级别（Window/Page.Resources）、全局级别（Application.Resources）。"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1️⃣ 命名样式 (x:Key) vs 隐式样式 (仅 TargetType)"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="命名样式需要显式引用 Style={}{StaticResource KeyName}，隐式样式会自动应用到所有目标类型的元素。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="命名样式按钮" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="另一个命名样式" Style="{StaticResource DangerButtonStyle}" />
                        <Button Content="未设置样式(默认)" />
                    </WrapPanel>
                    <TextBlock Text="上方：前两个引用了命名样式 PrimaryButtonStyle 和 DangerButtonStyle，第三个使用默认样式"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2️⃣ 样式继承 (BasedOn)" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="通过 BasedOn 可以实现样式继承，子样式继承父样式的所有属性，并可覆盖或新增属性。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="基础样式" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="继承-危险" Style="{StaticResource DangerButtonStyle}" />
                        <Button Content="继承-成功" Style="{StaticResource SuccessButtonStyle}" />
                    </WrapPanel>
                    <TextBlock Text="DangerButtonStyle 和 SuccessButtonStyle 都 BasedOn PrimaryButtonStyle，只修改了颜色"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3️⃣ TextBox 样式示例" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="带圆角边框和聚焦高亮效果的 TextBox 样式" TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBox Text="带样式的文本框" Style="{StaticResource InfoTextBoxStyle}"
                                 Width="200" />
                        <TextBox Text="默认文本框" Width="200" Margin="20,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="4️⃣ 隐式样式 (隐式自动应用)" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="注意：本页 Resources 中定义了 TargetType=&quot;TextBlock&quot; 的隐式样式（无 x:Key），"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="页面上所有未显式设置 FontSize 的 TextBlock 都会自动应用 FontSize=13"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="我就是被隐式样式影响的一个 TextBlock — 自动获得 FontSize=13"
                               Foreground="#E91E63" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="5️⃣ 样式级联 (Cascading) 验证" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="当一个元素同时被命名样式和隐式样式影响时，优先使用命名样式。样式优先级：内联属性 > 命名样式 > 隐式样式 > 默认值。"
                               TextWrapping="Wrap" Foreground="#757575" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📐 样式定义层级说明" Style="{StaticResource SubTitleText}" />
                    <StackPanel Margin="0,5">
                        <TextBlock Text="① Application.Resources — 全局共享，所有窗口可用" Foreground="#1976D2" />
                        <TextBlock Text="② Window.Resources — 窗口级别，当前窗口内可用" Foreground="#388E3C" />
                        <TextBlock Text="③ Page.Resources — 页面级别，当前页面内可用" Foreground="#F57C00" />
                        <TextBlock Text="④ 元素 Resources — 仅该元素及其子元素可用" Foreground="#7B1FA2" />
                        <TextBlock Text="⑤ 内联属性 — 直接在元素上设置，优先级最高" Foreground="#C62828" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🎯 最佳实践" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• 将通用样式放在 Application.Resources 或独立的 ResourceDictionary 中" />
                    <TextBlock Text="• 使用 BasedOn 减少重复代码" />
                    <TextBlock Text="• 命名样式用 x:Key，隐式样式仅用 TargetType" />
                    <TextBlock Text="• 提取颜色和尺寸为独立资源，便于主题切换" />
                    <TextBlock Text="• 用 ControlTemplate 定制控件外观（详见控件模板页面）" />
                </StackPanel>
            </Border>

            <TextBlock Text="🎉 样式让 UI 开发更高效、更统一！" FontSize="14"
                       Foreground="#BDBDBD" HorizontalAlignment="Center"
                       Margin="0,20" />
        </StackPanel>
    </ScrollViewer>
</Page>