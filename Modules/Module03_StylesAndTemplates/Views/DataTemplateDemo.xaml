<Page x:Class="LearnXaml.Modules.Module03_StylesAndTemplates.Views.DataTemplateDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module03_StylesAndTemplates.Views"
      xmlns:models="clr-namespace:LearnXaml.Models"
      Title="数据模板">

    <Page.Resources>
        <local:EnrolledToBgConverter x:Key="EnrolledToBgConverter" />
        <local:EnrolledToTextConverter x:Key="EnrolledToTextConverter" />

        <DataTemplate x:Key="StudentCardTemplate">
            <Border Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="15"
                    Margin="0,4"
                    Width="320">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.08" />
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#2196F3" CornerRadius="20" Width="36" Height="36"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding Name, StringFormat={}{0}}"
                                       Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#212121" />
                            <TextBlock FontSize="12" Foreground="#757575">
                                <Run Text="学号：" /><Run Text="{Binding Id}" />
                                <Run Text="  年级：" /><Run Text="{Binding Grade}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <Border Background="#F5F5F5" CornerRadius="4" Padding="8,4" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📧 " FontSize="12" />
                            <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#616161" />
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Border CornerRadius="10" Padding="6,2" Margin="0,0,8,0"
                                Background="{Binding IsEnrolled, Converter={StaticResource EnrolledToBgConverter}}">
                            <TextBlock FontSize="11"
                                       Text="{Binding IsEnrolled, Converter={StaticResource EnrolledToTextConverter}}" />
                        </Border>
                        <TextBlock Text="{Binding EnrollmentDate, StringFormat='yyyy-MM-dd 入学'}"
                                   FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StudentCompactTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Width="60"
                           Foreground="#212121" />
                <TextBlock Text="{Binding Grade}" Width="50" Foreground="#F57C00" />
                <TextBlock Text="{Binding Email}" Foreground="#757575" FontSize="12" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:Student}">
            <Border Background="#F0F7FF"
                    BorderBrush="#BBDEFB"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="0,3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="70"
                               Foreground="#1565C0" />
                    <TextBlock Text="{Binding Grade}" Width="50" Foreground="#F57C00" />
                    <TextBlock Text="{Binding Email}" Foreground="#757575" FontSize="12" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ComboStudentTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding Grade}" Foreground="#F57C00" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="DemoBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📋 数据模板 (DataTemplate)" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="💡 什么是 DataTemplate？" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="DataTemplate 定义「数据如何显示」。它告诉 WPF：当你遇到一条 Student 数据时，用这个视觉布局来呈现它。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="DataTemplate 作用于数据对象，ControlTemplate 作用于控件。两者互补，共同构成 WPF 的数据驱动 UI 体系。"
                               TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#F57C00" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="1️⃣ 学生卡片模板 — 带阴影和复杂布局"
                               Style="{StaticResource SubTitleText}" />
                    <ListBox x:Name="StudentCardList"
                             ItemTemplate="{StaticResource StudentCardTemplate}"
                             Background="Transparent" BorderThickness="0"
                             Width="360" MinHeight="200" />
                    <TextBlock Text="每个 ListBoxItem 使用 StudentCardTemplate 渲染：头像圆圈、姓名、学号、邮箱、入学状态标签"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="2️⃣ 紧凑列表模板 — 同一数据不同模板"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="相同的学生数据，使用不同的 DataTemplate 呈现完全不同风格（紧凑横向排列 vs 卡片式）"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <ListBox x:Name="StudentCompactList"
                             ItemTemplate="{StaticResource StudentCompactTemplate}"
                             Background="Transparent" BorderThickness="0"
                             Width="360" MinHeight="100" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="3️⃣ DataType 自动模板选择"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="当 DataTemplate 设置了 DataType 属性（未设 x:Key），WPF 会自动将匹配类型的数据对象应用此模板。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="这是最简洁的方式：只需定义 DataType，不需要显式指定 ItemTemplate。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <ListBox x:Name="StudentAutoList"
                             Background="Transparent" BorderThickness="0"
                             Width="360" MinHeight="100" />
                    <TextBlock Text="以上 ListBox 没有设置 ItemTemplate，但因为定义了 DataType=&quot;{x:Type models:Student}&quot; 的 DataTemplate，自动渲染为浅蓝色条"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="4️⃣ ComboBox + DataTemplate"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="DataTemplate 不仅用于 ListBox，同样可用于 ComboBox、ListView 等 ItemsControl 子类"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <ComboBox x:Name="StudentComboBox"
                              ItemTemplate="{StaticResource ComboStudentTemplate}"
                              Width="220" Height="32" Margin="0,10,0,0"
                              SelectedIndex="0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="5️⃣ ItemsControl 批量展示 — 水平排列"
                               Style="{StaticResource SubTitleText}" />
                    <ItemsControl x:Name="StudentItemsControl"
                                  ItemTemplate="{StaticResource StudentCardTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <TextBlock Text="ItemsControl 是轻量级的多项容器，配合 WrapPanel 实现卡片水平排列"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="📐 DataTemplate vs ControlTemplate 总结"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• ControlTemplate 回答：控件「长什么样」（按钮是圆的还是方的）" />
                    <TextBlock Text="• DataTemplate 回答：数据「如何展示」（学生显示为卡片还是行）" />
                    <TextBlock Text="• ControlTemplate 通过 TemplateBinding 绑定控件属性" />
                    <TextBlock Text="• DataTemplate 通过 {Binding} 绑定数据对象属性" />
                    <TextBlock Text="• 一个控件只能有一个 ControlTemplate" />
                    <TextBlock Text="• 不同类型的数据可以使用不同的 DataTemplate（通过 DataType 或 DataTemplateSelector）" />
                </StackPanel>
            </Border>

            <TextBlock Text="📋 数据模板让数据展示与数据本身完全解耦！"
                       FontSize="14" Foreground="#BDBDBD"
                       HorizontalAlignment="Center" Margin="0,20" />
        </StackPanel>
    </ScrollViewer>
</Page>