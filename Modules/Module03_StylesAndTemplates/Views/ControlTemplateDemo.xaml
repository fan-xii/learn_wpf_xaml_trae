<Page x:Class="LearnXaml.Modules.Module03_StylesAndTemplates.Views.ControlTemplateDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module03_StylesAndTemplates.Views"
      Title="控件模板">

    <Page.Resources>
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BgEllipse"
                                     Fill="#2196F3"
                                     Stroke="#1976D2"
                                     StrokeThickness="2" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="White"
                                              TextElement.FontWeight="Bold"
                                              TextElement.FontSize="20" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="#42A5F5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="#1565C0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BgEllipse" Property="Fill" Value="#BDBDBD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradientButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="45" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="GradientBorder" CornerRadius="22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4A00E0" Offset="0" />
                                    <GradientStop Color="#8E2DE2" Offset="0.5" />
                                    <GradientStop Color="#E94057" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.3" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="20,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GradientBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="GradientBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="80" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconBorder"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" Opacity="0.1" BlurRadius="6" />
                            </Border.Effect>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="IconText"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <ContentPresenter HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#E3F2FD" />
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#2196F3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconBorder" Property="Background" Value="#BBDEFB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="SwitchTrack"
                                    Width="44"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="#BDBDBD"
                                    Margin="0,0,8,0" />
                            <Border x:Name="SwitchThumb"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="2,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3" />
                                </Border.Effect>
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#4CAF50" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="22,0,0,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="TrackBackground"
                                    Height="{TemplateBinding Height}"
                                    Background="#E0E0E0"
                                    CornerRadius="8"
                                    MinHeight="16" />
                            <Border x:Name="PART_Indicator"
                                    Height="{TemplateBinding Height}"
                                    Background="#2196F3"
                                    CornerRadius="8"
                                    HorizontalAlignment="Left"
                                    MinHeight="16" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DemoBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="🔧 控件模板 (ControlTemplate)" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="💡 什么是控件模板？" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="ControlTemplate 定义控件的视觉结构和外观，它将控件的外观 (View) 与行为 (Logic) 完全分离。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="通过 ControlTemplate，你可以完全改变一个按钮的外观，同时保留其点击、命令等所有内置行为。"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="核心要素：TemplateBinding（属性绑定）、ContentPresenter（内容占位符）、VisualState（视觉状态）。"
                               TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#F57C00" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="1️⃣ 圆形按钮 — 使用 Ellipse 替换默认外观"
                               Style="{StaticResource SubTitleText}" />
                    <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
                        <Button Content="+" Style="{StaticResource RoundButtonStyle}" />
                        <Button Content="✓" Style="{StaticResource RoundButtonStyle}"
                                Foreground="White" Margin="15,0" />
                        <Button Content="✕" Style="{StaticResource RoundButtonStyle}"
                                Foreground="White" Margin="0,0,15,0" />
                        <Button Content="?" Style="{StaticResource RoundButtonStyle}"
                                IsEnabled="False" />
                    </WrapPanel>
                    <TextBlock Text="通过 ControlTemplate 将 Button 外观改为椭圆形，支持 IsMouseOver/IsPressed/IsEnabled 视觉状态"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="2️⃣ 渐变按钮 — LinearGradientBrush 模板"
                               Style="{StaticResource SubTitleText}" />
                    <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
                        <Button Content="渐变按钮" Style="{StaticResource GradientButtonStyle}" />
                        <Button x:Name="btnDefaultCompare" Content="默认按钮" Margin="15,0"
                                Width="140" Height="45" />
                    </WrapPanel>
                    <TextBlock Text="左：自定义渐变背景+阴影的模板  右：系统默认按钮外观  — 同样都是 Button，外观完全不同"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="3️⃣ 图标按钮 — Tag 绑定实现图标+文字"
                               Style="{StaticResource SubTitleText}" />
                    <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
                        <Button Content="保存" Tag="💾" Style="{StaticResource IconButtonStyle}" />
                        <Button Content="删除" Tag="🗑" Style="{StaticResource IconButtonStyle}" Margin="10,0" />
                        <Button Content="分享" Tag="📤" Style="{StaticResource IconButtonStyle}" Margin="0,0,10,0" />
                        <Button Content="设置" Tag="⚙" Style="{StaticResource IconButtonStyle}" />
                    </WrapPanel>
                    <TextBlock Text="TemplateBinding Tag 将图标字符绑定到 TextBlock，ContentPresenter 显示按钮文字"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="4️⃣ 开关 ToggleSwitch — CheckBox 控件模板"
                               Style="{StaticResource SubTitleText}" />
                    <StackPanel Margin="0,10,0,0">
                        <CheckBox Content="启用通知" Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="True" Margin="0,5" FontSize="14" />
                        <CheckBox Content="深色模式" Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="False" Margin="0,5" FontSize="14" />
                        <CheckBox Content="自动更新（禁用）" Style="{StaticResource ToggleSwitchStyle}"
                                  IsEnabled="False" Margin="0,5" FontSize="14" />
                        <CheckBox Content="普通复选框对比" Margin="0,10" FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="5️⃣ 自定义进度条 — ProgressBar 控件模板"
                               Style="{StaticResource SubTitleText}" />
                    <ProgressBar x:Name="CustomProgress"
                                 Style="{StaticResource CustomProgressBarStyle}"
                                 Value="65" Height="16"
                                 Width="400" Margin="0,10,0,0" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="0%" Click="ProgressTo0_Click" Margin="3"
                                Padding="10,5" />
                        <Button Content="30%" Click="ProgressTo30_Click" Margin="3"
                                Padding="10,5" />
                        <Button Content="65%" Click="ProgressTo65_Click" Margin="3"
                                Padding="10,5" />
                        <Button Content="100%" Click="ProgressTo100_Click" Margin="3"
                                Padding="10,5" />
                    </StackPanel>
                    <ProgressBar Value="40" Height="20" Width="400" Margin="0,10,0,0" />
                    <TextBlock Text="上方：自定义圆角蓝色进度条  下方：默认系统进度条（对比）"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,3,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="6️⃣ TemplateBinding 与 ContentPresenter 说明"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="TemplateBinding — 将模板内属性绑定到控件暴露的属性，如 Background、Padding、Width 等" />
                    <TextBlock Text="ContentPresenter — 内容占位符，显示控件 Content 属性的内容" />
                    <TextBlock Text="PART_ 命名约定 — 特定名称元素（如 PART_Indicator）被控件代码逻辑引用，用于交互" />
                    <TextBlock Text="VisualState — 通过 VisualStateManager 管理控件状态（WPF 中常用 Trigger 实现）" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="📐 ControlTemplate vs DataTemplate" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• ControlTemplate — 定义控件的「外观骨架」（一个按钮长什么样）" />
                    <TextBlock Text="• DataTemplate — 定义数据的「呈现方式」（一条学生数据如何显示）" />
                    <TextBlock Text="• ControlTemplate 属于控件级别 → 每个控件只有一个 ControlTemplate" />
                    <TextBlock Text="• DataTemplate 属于数据级别 → 不同数据可用不同 DataTemplate" />
                </StackPanel>
            </Border>

            <TextBlock Text="🔧 控件模板让 WPF 的 UI 自定义能力无限强大！"
                       FontSize="14" Foreground="#BDBDBD"
                       HorizontalAlignment="Center" Margin="0,20" />
        </StackPanel>
    </ScrollViewer>
</Page>