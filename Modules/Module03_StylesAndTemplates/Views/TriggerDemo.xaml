<Page x:Class="LearnXaml.Modules.Module03_StylesAndTemplates.Views.TriggerDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module03_StylesAndTemplates.Views"
      Title="触发器">

    <Page.Resources>
        <Style x:Key="HoverButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2" />
                    <Setter Property="FontSize" Value="15" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0" />
                    <Setter Property="FontSize" Value="13" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD" />
                    <Setter Property="Foreground" Value="#757575" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MultiTriggerButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="Transparent"
                                BorderThickness="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True" />
                        <Condition Property="IsFocused" Value="True" />
                    </MultiTrigger.Conditions>
                    <MultiTrigger.Setters>
                        <Setter Property="Background" Value="#FF9800" />
                        <Setter Property="Foreground" Value="#3E2723" />
                    </MultiTrigger.Setters>
                </MultiTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ValidationTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Width" Value="220" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="White"
                                BorderBrush="#BDBDBD"
                                BorderThickness="2"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#2196F3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DataTriggerBorder" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#E0E0E0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnrolled}" Value="True">
                    <Setter Property="Background" Value="#E8F5E9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnrolled}" Value="False">
                    <Setter Property="Background" Value="#FFEBEE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AgeDataTriggerBorder" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#E0E0E0" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsEnrolled}" Value="True" />
                        <Condition Binding="{Binding Age}" Value="22" />
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.Setters>
                        <Setter Property="Background" Value="#FFF8E1" />
                        <Setter Property="BorderBrush" Value="#FFC107" />
                        <Setter Property="BorderThickness" Value="2" />
                    </MultiDataTrigger.Setters>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DemoBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="⚡ 触发器 (Triggers)" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="💡 什么是触发器？" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="触发器 (Trigger) 是一种声明式机制，当满足特定条件时，自动改变控件的属性值。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="触发器让 UI 交互逻辑可以直接在 XAML 中声明，无需编写 C# 代码。"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="WPF 支持 5 种触发器类型：Property Trigger、MultiTrigger、DataTrigger、MultiDataTrigger、EventTrigger。"
                               TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#F57C00" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="1️⃣ Property Trigger — 属性触发器"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="当控件的某个属性值匹配条件时触发。最常用的触发器类型。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <WrapPanel>
                            <Button Content="悬停我 (IsMouseOver)" Style="{StaticResource HoverButton}" />
                            <Button Content="可点击 (IsEnabled=True)" Style="{StaticResource HoverButton}" />
                            <Button Content="已禁用 (IsEnabled=False)" Style="{StaticResource HoverButton}"
                                    IsEnabled="False" />
                        </WrapPanel>
                    </StackPanel>
                    <TextBlock Text="IsMouseOver → 背景变深+字号变大 | IsPressed → 背景更深+字号变小 | IsEnabled=False → 灰色外观"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="2️⃣ MultiTrigger — 多条件触发器"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="当多个属性条件同时满足时触发。所有条件必须都为 True。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <Button Content="点我先获得焦点，再悬停鼠标 → MultiTrigger 生效"
                                Style="{StaticResource MultiTriggerButton}" />
                    </StackPanel>
                    <TextBlock Text="条件：IsMouseOver=True 且 IsFocused=True → 变为橙色。单独悬停仅变深绿色。"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="3️⃣ 输入框聚焦效果 — Property Trigger 实战"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="TextBox 聚焦时边框变色是一个经典的 Property Trigger 应用"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <TextBox Text="点击我聚焦 - 边框变蓝"
                                 Style="{StaticResource ValidationTextBox}" />
                        <TextBox Text="再试试这个文本框"
                                 Style="{StaticResource ValidationTextBox}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="4️⃣ DataTrigger — 数据触发器"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="根据绑定的数据值来触发样式变化。与 Property Trigger 不同，DataTrigger 关注的是数据而非控件属性。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <Border Style="{StaticResource DataTriggerBorder}"
                                DataContext="{Binding Students[0]}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name, StringFormat=\{0\} — }" />
                                <TextBlock>
                                    <Run Text="在读状态: " /><Run Text="{Binding IsEnrolled}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DataTriggerBorder}"
                                DataContext="{Binding Students[2]}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name, StringFormat=\{0\} — }" />
                                <TextBlock>
                                    <Run Text="在读状态: " /><Run Text="{Binding IsEnrolled}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="IsEnrolled=True → 绿底 | IsEnrolled=False → 红底。完全由数据驱动！"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="5️⃣ MultiDataTrigger — 多数据条件触发器"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="同时满足多个数据条件时触发。例如：IsEnrolled=True 且 Age=22 的学生高亮显示。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <Border Style="{StaticResource AgeDataTriggerBorder}"
                                DataContext="{Binding Students[3]}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="60" />
                                <TextBlock Text="年龄:" /><TextBlock Text="{Binding Age}" Width="30" />
                                <TextBlock Text="在读:" /><TextBlock Text="{Binding IsEnrolled}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource AgeDataTriggerBorder}"
                                DataContext="{Binding Students[0]}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="60" />
                                <TextBlock Text="年龄:" /><TextBlock Text="{Binding Age}" Width="30" />
                                <TextBlock Text="在读:" /><TextBlock Text="{Binding IsEnrolled}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="赵六（在读，22岁）→ 黄色高亮+边框。张三（在读，20岁）→ 默认灰色。MultiDataTrigger 两个条件同时满足才触发。"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="6️⃣ EventTrigger — 事件触发器 + 动画"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="EventTrigger 在事件发生时触发，通常配合 Storyboard（动画）使用。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="最常用于：MouseEnter → 开始动画，MouseLeave → 停止/重置。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <Border x:Name="AnimatedBorder"
                            Background="#2196F3"
                            CornerRadius="8"
                            Width="120" Height="60"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0">
                        <TextBlock Text="悬停我"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                        To="#FF9800" Duration="0:0:0.3"
                                                        AutoReverse="True" RepeatBehavior="Forever" />
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="160" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetProperty="Height"
                                                         To="70" Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                                        To="#2196F3" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="120" Duration="0:0:0.3" />
                                        <DoubleAnimation Storyboard.TargetProperty="Height"
                                                         To="60" Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <TextBlock Text="MouseEnter → 变大+颜色变为橙色（循环闪烁） | MouseLeave → 恢复蓝色。纯 XAML 声明式动画！"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="7️⃣ EnterActions 和 ExitActions" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="Trigger 还支持 EnterActions 和 ExitActions，分别在进入和退出触发状态时执行。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <Button x:Name="ActionTriggerButton"
                                Content="悬停我触发 EnterActions/ExitActions"
                                Width="300" Height="40" FontSize="13"
                                Background="#9C27B0" Foreground="White"
                                Cursor="Hand"
                                BorderThickness="0" Padding="16,8" />
                    </StackPanel>
                    <TextBlock x:Name="ExitActionHint"
                               Text="EnterActions 和 ExitActions 可以用于执行更复杂的逻辑，如开始/停止动画、播放声音等。"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="📐 触发器类型总结" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• Trigger (Property Trigger) — 单个控件属性匹配 → 设置属性" />
                    <TextBlock Text="• MultiTrigger — 多个控件属性同时匹配 → 设置属性" />
                    <TextBlock Text="• DataTrigger — 单个数据绑定值匹配 → 设置属性" />
                    <TextBlock Text="• MultiDataTrigger — 多个数据绑定值同时匹配 → 设置属性" />
                    <TextBlock Text="• EventTrigger — 路由事件触发 → 执行 Storyboard/动画" />
                    <TextBlock Text="🎯 最佳实践：优先使用 Trigger 而非代码事件处理，保持 UI 逻辑在 XAML 中声明式定义！"
                               Foreground="#F57C00" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <TextBlock Text="⚡ 触发器让你的 UI 动起来，无需一行代码！"
                       FontSize="14" Foreground="#BDBDBD"
                       HorizontalAlignment="Center" Margin="0,20" />
        </StackPanel>
    </ScrollViewer>
</Page>