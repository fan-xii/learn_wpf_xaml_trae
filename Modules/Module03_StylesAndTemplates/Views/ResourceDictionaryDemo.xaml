<Page x:Class="LearnXaml.Modules.Module03_StylesAndTemplates.Views.ResourceDictionaryDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module03_StylesAndTemplates.Views"
      Title="资源字典">

    <Page.Resources>
        <SolidColorBrush x:Key="DynamicBgBrush" Color="#E3F2FD" />
        <SolidColorBrush x:Key="DynamicFgBrush" Color="#1565C0" />
        <SolidColorBrush x:Key="DynamicBorderBrush" Color="#90CAF9" />

        <SolidColorBrush x:Key="StaticBgBrush" Color="#E3F2FD" />
        <SolidColorBrush x:Key="StaticFgBrush" Color="#1565C0" />
        <SolidColorBrush x:Key="StaticBorderBrush" Color="#90CAF9" />

        <Style x:Key="ThemedButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource DynamicBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DynamicFgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DynamicBorderBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StaticBoundButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource StaticBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource StaticFgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StaticBorderBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DemoBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📦 资源字典 (ResourceDictionary)" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="💡 什么是资源字典？" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="ResourceDictionary 是 WPF 资源的集合容器，可以存放：Brush、Color、Style、DataTemplate、ControlTemplate、String、Double 等。"
                               TextWrapping="Wrap" />
                    <TextBlock Text="资源可以定义在：元素级别、容器级别、Application.Resources（全局）、独立的 .xaml 资源文件。"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="1️⃣ StaticResource vs DynamicResource — 实时对比"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="StaticResource：在加载时一次性查找，之后不会更新。性能好，但资源变化时不响应。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="DynamicResource：在运行时动态查找，资源变化时会自动更新。灵活但略有性能开销。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <StackPanel Margin="0,10,0,0">
                        <WrapPanel>
                            <Button Content="DynamicResource按钮"
                                    Style="{StaticResource ThemedButton}" />
                            <Button Content="StaticResource按钮"
                                    Style="{StaticResource StaticBoundButton}" />
                            <Button x:Name="ThemeBtn" Content="🔄 切换主题" Click="SwitchTheme_Click"
                                    Margin="20,0,0,0" Padding="16,8" FontSize="14"
                                    FontWeight="SemiBold" Background="#FF9800" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" />
                        </WrapPanel>
                    </StackPanel>
                    <TextBlock x:Name="ThemeStatusText"
                               Text="当前主题: 蓝色 (DynamicResource 和 StaticResource 颜色相同)"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,8,0,0" />
                    <TextBlock Text="点击「切换主题」后，DynamicResource 按钮会立即变色，StaticResource 按钮不会变化 — 这就是两者的核心区别！"
                               FontSize="12" Foreground="#E91E63" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="2️⃣ 多种资源类型示例" Style="{StaticResource SubTitleText}" />
                    <StackPanel Margin="0,5">
                        <Border Padding="10" Margin="0,3"
                                Background="{DynamicResource DynamicBgBrush}"
                                CornerRadius="4">
                            <TextBlock Text="这个 Border 使用了 DynamicResource DynamicBgBrush 作为背景色"
                                       Foreground="{DynamicResource DynamicFgBrush}" />
                        </Border>
                        <TextBlock Text="上方背景色也会随主题切换而变化（因为用了 DynamicResource）"
                                   FontSize="12" Foreground="#757575" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="3️⃣ 资源查找顺序 (Resource Lookup)" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="WPF 按以下顺序查找资源：" FontWeight="SemiBold" />
                    <TextBlock Text="① 当前元素的 Resources" Margin="20,2,0,0" />
                    <TextBlock Text="② 父元素的 Resources（逐级向上）" Margin="20,2,0,0" />
                    <TextBlock Text="③ Window/Page 的 Resources" Margin="20,2,0,0" />
                    <TextBlock Text="④ Application.Resources（全局）" Margin="20,2,0,0" />
                    <TextBlock Text="⑤ 系统资源（SystemColors, SystemFonts 等）" Margin="20,2,0,0" />
                    <TextBlock Text="找到第一个匹配的资源即停止查找。" Margin="0,4,0,0" Foreground="#F57C00" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="4️⃣ MergedDictionaries — 合并外部资源字典"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="通过 MergedDictionaries 可以将多个 .xaml 资源文件合并到一起使用。"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="本项目的 Application.Resources 已经合并了 SharedStyles.xaml，"
                               TextWrapping="Wrap" Foreground="#757575" />
                    <TextBlock Text="因此你可以在任何页面使用 TitleText、SubTitleText、DemoButton 等全局样式。"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="5️⃣ 何时使用 StaticResource vs DynamicResource"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="✅ 使用 StaticResource 的场景："
                               FontWeight="SemiBold" Foreground="#4CAF50" />
                    <TextBlock Text="• 资源值不会在运行时改变（如颜色常量、固定样式）" />
                    <TextBlock Text="• 追求最佳性能" />
                    <TextBlock Text="• 大多数常规 UI 样式" />
                    <TextBlock Text="✅ 使用 DynamicResource 的场景："
                               FontWeight="SemiBold" Foreground="#FF9800" Margin="0,10,0,0" />
                    <TextBlock Text="• 需要运行时切换主题/皮肤" />
                    <TextBlock Text="• 资源值依赖系统设置（如系统颜色、字体大小）" />
                    <TextBlock Text="• 资源值可能会动态更新" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource DemoBorder}">
                <StackPanel>
                    <TextBlock Text="📐 可存储的资源类型" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• Brush — 画刷（SolidColorBrush, LinearGradientBrush 等）" />
                    <TextBlock Text="• Color — 颜色常量" />
                    <TextBlock Text="• String — 字符串资源（如提示文本）" />
                    <TextBlock Text="• Double / Thickness — 尺寸和边距数值" />
                    <TextBlock Text="• Style — UI 样式" />
                    <TextBlock Text="• DataTemplate — 数据模板" />
                    <TextBlock Text="• ControlTemplate — 控件模板" />
                    <TextBlock Text="• Boolean / Int32 — 开关和数值" />
                    <TextBlock Text="• FontFamily — 字体资源" />
                </StackPanel>
            </Border>

            <TextBlock Text="📦 资源字典让 WPF 的主题和样式管理变得轻松优雅！"
                       FontSize="14" Foreground="#BDBDBD"
                       HorizontalAlignment="Center" Margin="0,20" />
        </StackPanel>
    </ScrollViewer>
</Page>