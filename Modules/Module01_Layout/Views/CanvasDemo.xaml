<Page x:Class="LearnXaml.Modules.Module01_Layout.Views.CanvasDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module01_Layout.Views"
      Title="Canvas 画布布局"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Canvas 画布布局" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📖 基本概念" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="Canvas 通过绝对坐标定位子元素，适合精确控制元素位置的场景。"
                               Foreground="#616161" TextWrapping="Wrap" Margin="0,3,0,0" />
                    <TextBlock Text="• Canvas.Left / Canvas.Top — 设置元素相对于 Canvas 左上角的坐标"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Canvas.Right / Canvas.Bottom — 设置元素相对于 Canvas 右下角的坐标"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Canvas.ZIndex — 控制重叠元素的层叠顺序（值越大越靠前）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 适合绘图、图表、游戏等需要精确坐标的场景"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🎯 绝对定位演示" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="通过 Canvas.Left 和 Canvas.Top 精确控制元素位置"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Background="White" Padding="5">
                        <Canvas Height="250" Background="#FAFAFA">
                            <Border Canvas.Left="10" Canvas.Top="10"
                                    Background="#42A5F5" CornerRadius="4" Padding="8" Width="100" Height="50">
                                <TextBlock Text="Left=10, Top=10" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Canvas.Right="10" Canvas.Top="10"
                                    Background="#66BB6A" CornerRadius="4" Padding="8" Width="100" Height="50">
                                <TextBlock Text="Right=10, Top=10" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Canvas.Left="10" Canvas.Bottom="10"
                                    Background="#FFA726" CornerRadius="4" Padding="8" Width="100" Height="50">
                                <TextBlock Text="Left=10, Bottom=10" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Canvas.Right="10" Canvas.Bottom="10"
                                    Background="#EF5350" CornerRadius="4" Padding="8" Width="100" Height="50">
                                <TextBlock Text="Right=10, Bottom=10" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border Canvas.Left="150" Canvas.Top="100"
                                    Background="#AB47BC" CornerRadius="4" Padding="8" Width="100" Height="50">
                                <TextBlock Text="Left=150, Top=100" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Ellipse Canvas.Left="350" Canvas.Top="80"
                                     Width="50" Height="50" Fill="#26A69A"
                                     Stroke="#00897B" StrokeThickness="2" />
                            <Rectangle Canvas.Left="370" Canvas.Top="140"
                                       Width="60" Height="40" Fill="#FF7043" RadiusX="4" RadiusY="4"
                                       Stroke="#E64A19" StrokeThickness="1" />
                        </Canvas>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🔝 Z-Order 层叠顺序" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="ZIndex 值越大，元素显示越靠上（默认 ZIndex=0）"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Background="White" Padding="5">
                        <Canvas Height="220" Background="#FAFAFA">
                            <Rectangle Canvas.Left="30" Canvas.Top="20"
                                       Width="100" Height="100" Fill="#42A5F5" RadiusX="8" RadiusY="8"
                                       Opacity="0.8" />
                            <TextBlock Canvas.Left="45" Canvas.Top="55" Text="Z=0（默认）"
                                       Foreground="White" FontWeight="Bold" FontSize="12" />

                            <Rectangle Canvas.Left="60" Canvas.Top="50"
                                       Width="100" Height="100" Fill="#66BB6A" RadiusX="8" RadiusY="8"
                                       Opacity="0.8" Panel.ZIndex="1" />
                            <TextBlock Canvas.Left="75" Canvas.Top="85" Text="Z=1"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       Panel.ZIndex="1" />

                            <Rectangle Canvas.Left="90" Canvas.Top="80"
                                       Width="100" Height="100" Fill="#FFA726" RadiusX="8" RadiusY="8"
                                       Opacity="0.8" Panel.ZIndex="2" />
                            <TextBlock Canvas.Left="105" Canvas.Top="115" Text="Z=2"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       Panel.ZIndex="2" />

                            <Rectangle Canvas.Left="120" Canvas.Top="110"
                                       Width="100" Height="100" Fill="#EF5350" RadiusX="8" RadiusY="8"
                                       Opacity="0.8" Panel.ZIndex="3" />
                            <TextBlock Canvas.Left="135" Canvas.Top="145" Text="Z=3（最前）"
                                       Foreground="White" FontWeight="Bold" FontSize="12"
                                       Panel.ZIndex="3" />

                            <TextBlock Canvas.Left="250" Canvas.Top="90"
                                       Text="ZIndex 越大越靠前显示" Foreground="#616161"
                                       FontSize="13" FontWeight="SemiBold" />
                        </Canvas>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🏠 房子绘图演示" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="综合使用 Canvas 和各种 Shape 控件绘制简单图形"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Background="White" Padding="5">
                        <Canvas Height="280" Background="#E8F5E9">
                            <Rectangle Canvas.Left="200" Canvas.Top="170"
                                       Width="130" Height="90" Fill="#FFCC80"
                                       Stroke="#F57C00" StrokeThickness="2" />

                            <Polygon Canvas.Left="200" Canvas.Top="70"
                                     Points="65,0 130,100 0,100" Fill="#FF7043"
                                     Stroke="#E64A19" StrokeThickness="2" />

                            <Rectangle Canvas.Left="240" Canvas.Top="200"
                                       Width="40" Height="60" Fill="#795548"
                                       Stroke="#5D4037" StrokeThickness="1" />

                            <Rectangle Canvas.Left="235" Canvas.Top="125"
                                       Width="30" Height="30" Fill="#81D4FA"
                                       Stroke="#4FC3F7" StrokeThickness="1" />
                            <Line Canvas.Left="250" Canvas.Top="125"
                                  X1="0" Y1="15" X2="0" Y2="30"
                                  Stroke="#4FC3F7" StrokeThickness="1" />
                            <Line Canvas.Left="235" Canvas.Top="140"
                                  X1="0" Y1="0" X2="30" Y2="0"
                                  Stroke="#4FC3F7" StrokeThickness="1" />

                            <Rectangle Canvas.Left="275" Canvas.Top="125"
                                       Width="30" Height="30" Fill="#81D4FA"
                                       Stroke="#4FC3F7" StrokeThickness="1" />
                            <Line Canvas.Left="290" Canvas.Top="125"
                                  X1="0" Y1="15" X2="0" Y2="30"
                                  Stroke="#4FC3F7" StrokeThickness="1" />
                            <Line Canvas.Left="275" Canvas.Top="140"
                                  X1="0" Y1="0" X2="30" Y2="0"
                                  Stroke="#4FC3F7" StrokeThickness="1" />

                            <Rectangle Canvas.Left="30" Canvas.Top="200"
                                       Width="80" Height="60" Fill="#A5D6A7"
                                       Stroke="#66BB6A" StrokeThickness="1" />
                            <TextBlock Canvas.Left="50" Canvas.Top="222"
                                       Text="草地" FontSize="12" Foreground="#2E7D32" />

                            <Ellipse Canvas.Left="460" Canvas.Top="30"
                                     Width="60" Height="60" Fill="#FFEB3B"
                                     Stroke="#F9A825" StrokeThickness="1" />
                            <TextBlock Canvas.Left="472" Canvas.Top="48"
                                       Text="太阳" FontSize="12" Foreground="#F57F17" />

                            <Line Canvas.Left="0" Canvas.Top="260"
                                  X1="0" Y1="0" X2="530" Y2="0"
                                  Stroke="#795548" StrokeThickness="3" />

                            <TextBlock Canvas.Left="30" Canvas.Top="20"
                                       Text="使用 Canvas 绘制的房子" FontWeight="Bold"
                                       FontSize="14" Foreground="#2E7D32" />
                        </Canvas>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📐 坐标参照线演示" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="Canvas 坐标原点在左上角 (0, 0)，向右为 X 正方向，向下为 Y 正方向"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Background="White" Padding="5">
                        <Canvas Height="200" Background="White">
                            <Line X1="30" Y1="180" X2="30" Y2="10"
                                  Stroke="#BDBDBD" StrokeThickness="1" StrokeDashArray="4,4" />
                            <Line X1="30" Y1="180" X2="400" Y2="180"
                                  Stroke="#BDBDBD" StrokeThickness="1" StrokeDashArray="4,4" />

                            <TextBlock Canvas.Left="5" Canvas.Top="0" Text="(0,0)"
                                       Foreground="#757575" FontSize="10" />
                            <TextBlock Canvas.Left="10" Canvas.Top="182" Text="X→"
                                       Foreground="#757575" FontSize="10" />
                            <TextBlock Canvas.Left="22" Canvas.Top="0" Text="Y↓"
                                       Foreground="#757575" FontSize="10" />

                            <Ellipse Canvas.Left="60" Canvas.Top="180"
                                     Width="10" Height="10" Fill="#F44336" />
                            <TextBlock Canvas.Left="55" Canvas.Top="190" Text="(60,180)"
                                       Foreground="#F44336" FontSize="10" />
                            <Line X1="360" Y1="190" X2="360" Y2="190"
                                  Stroke="Transparent" />

                            <Ellipse Canvas.Left="130" Canvas.Top="130"
                                     Width="10" Height="10" Fill="#2196F3" />
                            <TextBlock Canvas.Left="125" Canvas.Top="140" Text="(130,130)"
                                       Foreground="#2196F3" FontSize="10" />

                            <Ellipse Canvas.Left="200" Canvas.Top="80"
                                     Width="10" Height="10" Fill="#4CAF50" />
                            <TextBlock Canvas.Left="195" Canvas.Top="90" Text="(200,80)"
                                       Foreground="#4CAF50" FontSize="10" />

                            <Ellipse Canvas.Left="300" Canvas.Top="40"
                                     Width="10" Height="10" Fill="#FF9800" />
                            <TextBlock Canvas.Left="295" Canvas.Top="50" Text="(300,40)"
                                       Foreground="#FF9800" FontSize="10" />
                        </Canvas>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="💡 Canvas 关键要点" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• Canvas 使用绝对坐标定位，元素位置不会受其他元素影响"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• (0,0) 原点在 Canvas 的左上角"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 通过 ZIndex 可以控制重叠元素的显示顺序"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Canvas 不会自动调整子元素大小，每个元素需要显式设置宽高"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 适合需要精确定位的场景（绘图、图表、游戏等），不适合响应式布局"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>