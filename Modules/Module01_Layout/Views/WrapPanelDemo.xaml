<Page x:Class="LearnXaml.Modules.Module01_Layout.Views.WrapPanelDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module01_Layout.Views"
      Title="WrapPanel 环绕布局"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="WrapPanel 环绕布局" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📖 基本概念" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="WrapPanel 将子元素按行或列排列，当空间不足时自动换行/换列。"
                               Foreground="#616161" TextWrapping="Wrap" Margin="0,3,0,0" />
                    <TextBlock Text="• Orientation — Horizontal（水平排列换行）/ Vertical（垂直排列换列）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• ItemWidth / ItemHeight — 统一设置每个子元素的尺寸"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 适合图片画廊、标签云、工具栏按钮组等场景"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🖼 水平 WrapPanel（画廊布局）" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="设置了 ItemWidth=100 和 ItemHeight=80，元素自动换行排列"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="10" Background="White">
                        <WrapPanel Orientation="Horizontal" ItemWidth="100" ItemHeight="80">
                            <Border Background="#F44336" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📕" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="红色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#E91E63" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📗" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="粉色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#9C27B0" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📘" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="紫色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#673AB7" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📙" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="深紫" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#3F51B5" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📓" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="靛蓝" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#2196F3" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📔" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="蓝色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#00BCD4" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📒" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="青色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#009688" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="蓝绿" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#4CAF50" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📖" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="绿色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#8BC34A" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🔖" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="浅绿" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FFC107" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📑" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="琥珀" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FF9800" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="橙色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#795548" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📃" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="棕色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#607D8B" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="蓝灰" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#9E9E9E" CornerRadius="4" Margin="4">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="灰色" FontSize="11" Foreground="White"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🏷 标签云（自适应换行）" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="没有设置 ItemWidth/ItemHeight，每个元素根据内容自动调整大小"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="10" Background="White">
                        <WrapPanel Orientation="Horizontal">
                            <Border Background="#E3F2FD" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="WPF" Foreground="#1565C0" FontSize="12" />
                            </Border>
                            <Border Background="#FCE4EC" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="XAML" Foreground="#C62828" FontSize="12" />
                            </Border>
                            <Border Background="#E8F5E9" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="布局" Foreground="#2E7D32" FontSize="14" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#FFF3E0" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="Grid" Foreground="#E65100" FontSize="12" />
                            </Border>
                            <Border Background="#F3E5F5" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="StackPanel" Foreground="#6A1B9A" FontSize="12" />
                            </Border>
                            <Border Background="#E0F7FA" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="DockPanel" Foreground="#006064" FontSize="12" />
                            </Border>
                            <Border Background="#FFF8E1" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="WrapPanel" Foreground="#F57F17" FontSize="14" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#EFEBE9" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="Canvas" Foreground="#3E2723" FontSize="12" />
                            </Border>
                            <Border Background="#E8EAF6" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="UniformGrid" Foreground="#1A237E" FontSize="12" />
                            </Border>
                            <Border Background="#F1F8E9" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="MVVM" Foreground="#33691E" FontSize="13" />
                            </Border>
                            <Border Background="#FBE9E7" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="数据绑定" Foreground="#BF360C" FontSize="16" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#ECEFF1" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="样式" Foreground="#37474F" FontSize="12" />
                            </Border>
                            <Border Background="#F9FBE7" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="模板" Foreground="#827717" FontSize="12" />
                            </Border>
                            <Border Background="#EDE7F6" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="动画" Foreground="#311B92" FontSize="12" />
                            </Border>
                            <Border Background="#FFEBEE" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="路由事件" Foreground="#B71C1C" FontSize="12" />
                            </Border>
                            <Border Background="#E0F2F1" CornerRadius="12" Padding="8,4" Margin="3">
                                <TextBlock Text="依赖属性" Foreground="#004D40" FontSize="13" />
                            </Border>
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="↕↔ 方向对比" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="对比水平和垂直两种 Orientation 的排列效果"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <StackPanel Orientation="Horizontal">
                        <Border BorderBrush="#BBDEFB" BorderThickness="2" CornerRadius="4"
                                Padding="10" Margin="5" Background="White" MinWidth="350">
                            <StackPanel>
                                <TextBlock Text="水平 (Horizontal)" FontWeight="Bold"
                                           Foreground="#1565C0" Margin="0,0,0,8" />
                                <WrapPanel Orientation="Horizontal" ItemWidth="60" ItemHeight="40"
                                           Background="#F5F5F5" MaxWidth="300">
                                    <Border Background="#42A5F5" CornerRadius="3" Margin="2">
                                        <TextBlock Text="1" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#66BB6A" CornerRadius="3" Margin="2">
                                        <TextBlock Text="2" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FFA726" CornerRadius="3" Margin="2">
                                        <TextBlock Text="3" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#EF5350" CornerRadius="3" Margin="2">
                                        <TextBlock Text="4" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#AB47BC" CornerRadius="3" Margin="2">
                                        <TextBlock Text="5" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#26A69A" CornerRadius="3" Margin="2">
                                        <TextBlock Text="6" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FF7043" CornerRadius="3" Margin="2">
                                        <TextBlock Text="7" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#5C6BC0" CornerRadius="3" Margin="2">
                                        <TextBlock Text="8" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text="▲ 从左到右排列，到头后换行"
                                           Foreground="#9E9E9E" FontSize="11" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#FFCDD2" BorderThickness="2" CornerRadius="4"
                                Padding="10" Margin="5" Background="White" MinWidth="350">
                            <StackPanel>
                                <TextBlock Text="垂直 (Vertical)" FontWeight="Bold"
                                           Foreground="#C62828" Margin="0,0,0,8" />
                                <WrapPanel Orientation="Vertical" ItemWidth="40" ItemHeight="40"
                                           Background="#F5F5F5" MaxHeight="180">
                                    <Border Background="#42A5F5" CornerRadius="3" Margin="2">
                                        <TextBlock Text="1" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#66BB6A" CornerRadius="3" Margin="2">
                                        <TextBlock Text="2" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FFA726" CornerRadius="3" Margin="2">
                                        <TextBlock Text="3" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#EF5350" CornerRadius="3" Margin="2">
                                        <TextBlock Text="4" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#AB47BC" CornerRadius="3" Margin="2">
                                        <TextBlock Text="5" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#26A69A" CornerRadius="3" Margin="2">
                                        <TextBlock Text="6" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FF7043" CornerRadius="3" Margin="2">
                                        <TextBlock Text="7" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#5C6BC0" CornerRadius="3" Margin="2">
                                        <TextBlock Text="8" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text="▲ 从上到下排列，到底后换列"
                                           Foreground="#9E9E9E" FontSize="11" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="💡 WrapPanel 关键要点" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• WrapPanel 自动处理元素换行/换列，无需手动计算位置"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• ItemWidth/ItemHeight 可以统一子元素尺寸，也可不设置让其自适应"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Horizontal 模式适合横向排列的标签、卡片等"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Vertical 模式适合纵向排列的列表项（需要限制 MaxHeight）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 结合 ScrollViewer 可以实现可滚动的自适应布局"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>