<Page x:Class="LearnXaml.Modules.Module01_Layout.Views.StackPanelDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module01_Layout.Views"
      Title="StackPanel 堆叠布局"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="StackPanel 堆叠布局" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📖 基本概念" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="StackPanel 将子元素按水平或垂直方向依次排列（堆叠）。"
                               Foreground="#616161" TextWrapping="Wrap" Margin="0,3,0,0" />
                    <TextBlock Text="• Orientation — Vertical（垂直，默认）/ Horizontal（水平）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 每个子元素占据一行（垂直）或一列（水平）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 适合简单的线性布局场景"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="↕ 垂直 StackPanel" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="默认 Orientation=&quot;Vertical&quot;，子元素从上到下依次排列"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#BBDEFB" BorderThickness="1" CornerRadius="4"
                            Padding="10" Background="White">
                        <StackPanel Orientation="Vertical">
                            <Button Content="按钮 1" Style="{StaticResource DemoButton}"
                                    Margin="5,4" HorizontalAlignment="Stretch" />
                            <Button Content="按钮 2（居中）" Style="{StaticResource DemoButton}"
                                    Margin="5,4" HorizontalAlignment="Center" />
                            <Button Content="按钮 3（靠右）" Style="{StaticResource DemoButton}"
                                    Margin="5,4" HorizontalAlignment="Right" />
                            <TextBlock Text="文本块" FontSize="14" Margin="5,4"
                                       HorizontalAlignment="Center" Foreground="#616161" />
                            <CheckBox Content="复选框" Margin="5,4" />
                            <RadioButton Content="单选框" Margin="5,4" IsChecked="True" />
                            <Rectangle Height="30" Fill="{StaticResource AccentBrush}"
                                       Margin="5,4" RadiusX="4" RadiusY="4" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="▲ 每个元素按添加顺序从上到下堆叠，宽度默认填满 StackPanel"
                               Foreground="#9E9E9E" FontSize="12" Margin="5,8,5,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="↔ 水平 StackPanel" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="设置 Orientation=&quot;Horizontal&quot;，子元素从左到右依次排列"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="4"
                            Padding="10" Background="White">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="左" Style="{StaticResource DemoButton}"
                                    Margin="4,0" />
                            <Button Content="中" Style="{StaticResource DemoButton}"
                                    Margin="4,0" VerticalAlignment="Center" />
                            <Button Content="右（靠底）" Style="{StaticResource DemoButton}"
                                    Margin="4,0" VerticalAlignment="Bottom" />
                            <TextBlock Text="文本" FontSize="14" Margin="8,0"
                                       VerticalAlignment="Center" Foreground="#616161" />
                            <CheckBox Content="选我" Margin="4,0" VerticalAlignment="Center" />
                            <Ellipse Width="30" Height="30" Fill="{StaticResource SecondaryBrush}"
                                     Margin="4,0" />
                            <Rectangle Width="30" Height="30" Fill="{StaticResource DangerBrush}"
                                       Margin="4,0" RadiusX="4" RadiusY="4" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="▲ 每个元素按添加顺序从左到右排列，高度默认填满 StackPanel"
                               Foreground="#9E9E9E" FontSize="12" Margin="5,8,5,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🔀 嵌套 StackPanel" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="StackPanel 可以嵌套使用，实现复杂的布局组合"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E1BEE7" BorderThickness="1" CornerRadius="4"
                            Padding="15" Background="White">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="📝 用户信息表单（嵌套StackPanel示例）"
                                       FontWeight="Bold" FontSize="14"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10" />

                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="姓名：" Width="80" VerticalAlignment="Center"
                                           Foreground="#424242" FontWeight="SemiBold" />
                                <TextBox Width="200" Padding="4" BorderBrush="#BDBDBD" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="邮箱：" Width="80" VerticalAlignment="Center"
                                           Foreground="#424242" FontWeight="SemiBold" />
                                <TextBox Width="200" Padding="4" BorderBrush="#BDBDBD" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="年龄：" Width="80" VerticalAlignment="Center"
                                           Foreground="#424242" FontWeight="SemiBold" />
                                <TextBox Width="80" Padding="4" BorderBrush="#BDBDBD" Text="25" />
                                <TextBlock Text="岁" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="#757575" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Right">
                                <Button Content="取消" Style="{StaticResource DemoButton}"
                                        Background="#9E9E9E" />
                                <Button Content="提交" Style="{StaticResource DemoButton}"
                                        Background="{StaticResource AccentBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📏 对齐方式 与 Margin/Padding" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="子元素通过 HorizontalAlignment 和 VerticalAlignment 控制对齐"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#FFCCBC" BorderThickness="1" CornerRadius="4"
                            Padding="10" Background="White">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Margin（外间距）演示：" FontWeight="SemiBold"
                                       Foreground="#E64A19" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FFCC80" Margin="20,10" Padding="8" CornerRadius="3">
                                    <TextBlock Text="Margin=20,10" FontSize="12" />
                                </Border>
                                <Border Background="#A5D6A7" Margin="5,20" Padding="8" CornerRadius="3">
                                    <TextBlock Text="Margin=5,20" FontSize="12" />
                                </Border>
                                <Border Background="#90CAF9" Margin="10,10" Padding="8" CornerRadius="3">
                                    <TextBlock Text="Margin=10,10" FontSize="12" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Padding（内间距）演示：" FontWeight="SemiBold"
                                       Foreground="#E64A19" Margin="0,12,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#FFCC80" CornerRadius="3" Margin="4">
                                    <TextBlock Text="无Padding" FontSize="12" />
                                </Border>
                                <Border Background="#FFCC80" Padding="8" CornerRadius="3" Margin="4">
                                    <TextBlock Text="Padding=8" FontSize="12" />
                                </Border>
                                <Border Background="#FFCC80" Padding="16,8" CornerRadius="3" Margin="4">
                                    <TextBlock Text="Padding=16,8" FontSize="12" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🔍 方向对比" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="并排展示垂直和水平 StackPanel 的效果差异"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <StackPanel Orientation="Horizontal">
                        <Border BorderBrush="#BBDEFB" BorderThickness="2" CornerRadius="4"
                                Padding="10" Margin="5" Background="White" MinWidth="200">
                            <StackPanel>
                                <TextBlock Text="垂直 (Vertical)" FontWeight="Bold"
                                           Foreground="#1565C0" Margin="0,0,0,8" />
                                <StackPanel Orientation="Vertical">
                                    <Rectangle Height="20" Width="60" Fill="#42A5F5" Margin="2" RadiusX="3" RadiusY="3" />
                                    <Rectangle Height="20" Width="60" Fill="#66BB6A" Margin="2" RadiusX="3" RadiusY="3" />
                                    <Rectangle Height="20" Width="60" Fill="#FFA726" Margin="2" RadiusX="3" RadiusY="3" />
                                    <Rectangle Height="20" Width="60" Fill="#EF5350" Margin="2" RadiusX="3" RadiusY="3" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#C8E6C9" BorderThickness="2" CornerRadius="4"
                                Padding="10" Margin="5" Background="White" MinWidth="200">
                            <StackPanel>
                                <TextBlock Text="水平 (Horizontal)" FontWeight="Bold"
                                           Foreground="#2E7D32" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="60" Fill="#42A5F5" Margin="2" RadiusX="3" RadiusY="3" />
                                    <Rectangle Width="20" Height="60" Fill="#66BB6A" Margin="2" RadiusX="3" RadiusY="3" />
                                    <Rectangle Width="20" Height="60" Fill="#FFA726" Margin="2" RadiusX="3" RadiusY="3" />
                                    <Rectangle Width="20" Height="60" Fill="#EF5350" Margin="2" RadiusX="3" RadiusY="3" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="💡 StackPanel 关键要点" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• StackPanel 是最简单的布局面板，用于线性排列元素"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 垂直 StackPanel 中，子元素宽度默认拉伸填满（Stretch）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 水平 StackPanel 中，子元素高度默认拉伸填满（Stretch）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 嵌套 StackPanel 可以实现类似 Grid 的复杂布局"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Margin 控制元素与外部边界的间距，Padding 控制内容与元素边界的间距"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>