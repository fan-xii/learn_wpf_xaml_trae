<Page x:Class="LearnXaml.Modules.Module01_Layout.Views.GridDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module01_Layout.Views"
      Title="Grid 网格布局"
      Background="{StaticResource BgBrush}"
      TextOptions.TextFormattingMode="Display"
      UseLayoutRounding="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Grid 网格布局" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📖 基本概念" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="Grid 是 WPF 中最强大、最灵活的布局面板。它将内容组织成行和列的网格。" 
                               Foreground="#616161" TextWrapping="Wrap" Margin="0,3,0,0" />
                    <TextBlock Text="• RowDefinitions — 定义行（Auto / * / 固定像素）" Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• ColumnDefinitions — 定义列（Auto / * / 固定像素）" Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Grid.Row / Grid.Column — 指定子元素位置（从 0 开始）" Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Grid.RowSpan / Grid.ColumnSpan — 跨行/跨列" Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📐 尺寸类型演示" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="展示 Auto（根据内容自动）、*（比例分配）、固定像素 三种尺寸模式" 
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Grid ShowGridLines="True" Height="160" Background="White">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Auto Column" Grid.Row="0" Grid.Column="0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#1976D2" FontWeight="Bold" />
                        <TextBlock Text="1* Column" Grid.Row="0" Grid.Column="1"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#388E3C" FontWeight="Bold" />
                        <TextBlock Text="100px Column" Grid.Row="0" Grid.Column="2"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#7B1FA2" FontWeight="Bold" />

                        <TextBlock Text="Auto Row" Grid.Row="1" Grid.Column="0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#1976D2" FontWeight="Bold" />
                        <TextBlock Text="1* Row" Grid.Row="2" Grid.Column="0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#388E3C" FontWeight="Bold" />
                        <TextBlock Text="2* Row" Grid.Row="3" Grid.Column="0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#E64A19" FontWeight="Bold" />
                        <TextBlock Text="40px Row" Grid.Row="4" Grid.Column="0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#7B1FA2" FontWeight="Bold" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🧮 计算器布局示例" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="这是一个使用 Grid 构建的经典计算器界面，展示了 RowSpan 和 ColumnSpan 的用法" 
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Grid Width="280" Background="#ECEFF1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="CalculatorDisplay" Grid.Row="0" Grid.ColumnSpan="4" Text="0"
                                 HorizontalAlignment="Stretch" Margin="4" Padding="8,12"
                                 FontSize="22" TextAlignment="Right"
                                 Background="White" BorderBrush="#BDBDBD" IsReadOnly="True" />

                        <Button Grid.Row="1" Grid.Column="0" Content="C" Margin="2" Click="ClearButton_Click"
                                Background="#F44336" Foreground="White" FontWeight="Bold" />
                        <Button Grid.Row="1" Grid.Column="1" Content="±" Margin="2" Click="NegateButton_Click" />
                        <Button Grid.Row="1" Grid.Column="2" Content="%" Margin="2" Click="PercentButton_Click" />
                        <Button Grid.Row="1" Grid.Column="3" Content="÷" Margin="2" Click="OperatorButton_Click"
                                Background="{StaticResource SecondaryBrush}" Foreground="White"
                                FontWeight="Bold" />

                        <Button Grid.Row="2" Grid.Column="0" Content="7" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="2" Grid.Column="3" Content="×" Margin="2" Click="OperatorButton_Click"
                                Background="{StaticResource SecondaryBrush}" Foreground="White"
                                FontWeight="Bold" />

                        <Button Grid.Row="3" Grid.Column="0" Content="4" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="3" Grid.Column="1" Content="5" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="3" Grid.Column="2" Content="6" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="3" Grid.Column="3" Content="−" Margin="2" Click="OperatorButton_Click"
                                Background="{StaticResource SecondaryBrush}" Foreground="White"
                                FontWeight="Bold" />

                        <Button Grid.Row="4" Grid.Column="0" Content="1" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="4" Grid.Column="1" Content="2" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="4" Grid.Column="2" Content="3" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="4" Grid.Column="3" Content="+" Margin="2" Click="OperatorButton_Click"
                                Background="{StaticResource SecondaryBrush}" Foreground="White"
                                FontWeight="Bold" />

                        <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                Content="0" Margin="2" Click="NumberButton_Click" />
                        <Button Grid.Row="5" Grid.Column="2" Content="." Margin="2" Click="DecimalButton_Click" />
                        <Button Grid.Row="5" Grid.Column="3" Content="=" Margin="2" Click="EqualsButton_Click"
                                Background="{StaticResource PrimaryBrush}" Foreground="White"
                                FontWeight="Bold" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📋 跨行跨列演示" Style="{StaticResource SubTitleText}" />
                    <Grid ShowGridLines="True" Height="150" Background="White"
                          MaxWidth="500">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                                Background="#BBDEFB" CornerRadius="4" Margin="3">
                            <TextBlock Text="ColumnSpan=4（跨4列）" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#1565C0" FontWeight="Bold" />
                        </Border>
                        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                                Background="#C8E6C9" CornerRadius="4" Margin="3">
                            <TextBlock Text="RowSpan=2&#x0a;（跨2行）" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#2E7D32" FontWeight="Bold"
                                       TextAlignment="Center" />
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1"
                                Background="#FFF9C4" CornerRadius="4" Margin="3">
                            <TextBlock Text="(1,1)" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#F57F17" FontWeight="Bold" />
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                Background="#FFCCBC" CornerRadius="4" Margin="3">
                            <TextBlock Text="ColSpan=2" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#BF360C" FontWeight="Bold" />
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                                Background="#E1BEE7" CornerRadius="4" Margin="3">
                            <TextBlock Text="(2,1) + ColSpan=3" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#6A1B9A" FontWeight="Bold" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="💡 Grid 关键要点" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• Grid 默认只有1行1列，需要显式定义 RowDefinitions 和 ColumnDefinitions" 
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Grid.Row 和 Grid.Column 属性从 0 开始计数" 
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 使用 ShowGridLines=&quot;True&quot; 可以在设计时查看网格线" 
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• * 表示按比例分配剩余空间，2* 表示占两份" 
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Auto 表示根据内容自动调整大小" 
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• Grid 是大多数 WPF 应用界面的基础布局面板" 
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>