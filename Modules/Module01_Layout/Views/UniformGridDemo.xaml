<Page x:Class="LearnXaml.Modules.Module01_Layout.Views.UniformGridDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module01_Layout.Views"
      Title="UniformGrid 均匀网格布局"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="UniformGrid 均匀网格布局" Style="{StaticResource TitleText}" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="📖 基本概念" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="UniformGrid 将所有子元素放入大小完全相同的单元格中，单元格大小由面板总大小自动计算。"
                               Foreground="#616161" TextWrapping="Wrap" Margin="0,3,0,0" />
                    <TextBlock Text="• Rows / Columns — 指定网格的行数和列数"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 如果不设置 Rows/Columns，会自动计算行列使单元格尽量接近正方形"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 所有单元格大小完全相同"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 元素按添加顺序从左到右、从上到下填充"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🎨 色卡展示" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="6个元素在 3行×2列 的 UniformGrid 中自动均分"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="5" Background="White">
                        <UniformGrid Rows="3" Columns="2" Height="240">
                            <Border Background="#F44336" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="#F44336" Foreground="White"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="红色 Red" Foreground="#FFCDD2"
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FF9800" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="#FF9800" Foreground="White"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="橙色 Orange" Foreground="#FFE0B2"
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FFEB3B" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="#FFEB3B" Foreground="#212121"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="黄色 Yellow" Foreground="#827717"
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#4CAF50" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="#4CAF50" Foreground="White"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="绿色 Green" Foreground="#C8E6C9"
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#2196F3" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="#2196F3" Foreground="White"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="蓝色 Blue" Foreground="#BBDEFB"
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#9C27B0" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="#9C27B0" Foreground="White"
                                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="紫色 Purple" Foreground="#E1BEE7"
                                               FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="♟ 棋盘格图案" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="8行×8列 的 Chessboard 风格布局演示"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="5" Background="White">
                        <UniformGrid Rows="8" Columns="8" Width="400" Height="400">
                            <Border Background="#FFFFFF" Grid.Row="0" Grid.Column="0" />
                            <Border Background="#424242" Grid.Row="0" Grid.Column="1" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />

                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />

                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />

                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
