                            <Border Background="#FFFFFF" />

                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />

                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />

                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />

                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                            <Border Background="#424242" />
                            <Border Background="#FFFFFF" />
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="🔢 数字九宫格" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="3行×3列 的数字布局演示"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                            Padding="5" Background="White">
                        <UniformGrid Rows="3" Columns="3" Height="240" Width="320">
                            <Border Background="#E3F2FD" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="1" FontSize="32" FontWeight="Bold"
                                               Foreground="#1565C0" HorizontalAlignment="Center" />
                                    <TextBlock Text="第一格" FontSize="12" Foreground="#1976D2"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#E8F5E9" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="2" FontSize="32" FontWeight="Bold"
                                               Foreground="#2E7D32" HorizontalAlignment="Center" />
                                    <TextBlock Text="第二格" FontSize="12" Foreground="#388E3C"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FFF3E0" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="3" FontSize="32" FontWeight="Bold"
                                               Foreground="#E65100" HorizontalAlignment="Center" />
                                    <TextBlock Text="第三格" FontSize="12" Foreground="#F57C00"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FCE4EC" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="4" FontSize="32" FontWeight="Bold"
                                               Foreground="#C62828" HorizontalAlignment="Center" />
                                    <TextBlock Text="第四格" FontSize="12" Foreground="#D32F2F"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#F3E5F5" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="5" FontSize="32" FontWeight="Bold"
                                               Foreground="#6A1B9A" HorizontalAlignment="Center" />
                                    <TextBlock Text="第五格" FontSize="12" Foreground="#7B1FA2"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#E0F7FA" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="6" FontSize="32" FontWeight="Bold"
                                               Foreground="#006064" HorizontalAlignment="Center" />
                                    <TextBlock Text="第六格" FontSize="12" Foreground="#00838F"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FFF8E1" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="7" FontSize="32" FontWeight="Bold"
                                               Foreground="#F57F17" HorizontalAlignment="Center" />
                                    <TextBlock Text="第七格" FontSize="12" Foreground="#F9A825"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#EFEBE9" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="8" FontSize="32" FontWeight="Bold"
                                               Foreground="#3E2723" HorizontalAlignment="Center" />
                                    <TextBlock Text="第八格" FontSize="12" Foreground="#4E342E"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="#E8EAF6" CornerRadius="4" Margin="3">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="9" FontSize="32" FontWeight="Bold"
                                               Foreground="#1A237E" HorizontalAlignment="Center" />
                                    <TextBlock Text="第九格" FontSize="12" Foreground="#283593"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="⚙ Rows/Columns 效果对比" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="对比不同 Rows/Columns 组合的布局效果"
                               Foreground="#757575" Margin="0,0,0,10" />

                    <StackPanel Orientation="Horizontal">
                        <Border BorderBrush="#BBDEFB" BorderThickness="2" CornerRadius="4"
                                Padding="10" Margin="5" Background="White">
                            <StackPanel>
                                <TextBlock Text="Rows=2, Columns=4" FontWeight="Bold"
                                           Foreground="#1565C0" Margin="0,0,0,8" />
                                <UniformGrid Rows="2" Columns="4" Height="100" Width="300">
                                    <Border Background="#42A5F5" CornerRadius="2" Margin="2">
                                        <TextBlock Text="1" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#66BB6A" CornerRadius="2" Margin="2">
                                        <TextBlock Text="2" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FFA726" CornerRadius="2" Margin="2">
                                        <TextBlock Text="3" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#EF5350" CornerRadius="2" Margin="2">
                                        <TextBlock Text="4" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#AB47BC" CornerRadius="2" Margin="2">
                                        <TextBlock Text="5" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#26A69A" CornerRadius="2" Margin="2">
                                        <TextBlock Text="6" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FF7043" CornerRadius="2" Margin="2">
                                        <TextBlock Text="7" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#5C6BC0" CornerRadius="2" Margin="2">
                                        <TextBlock Text="8" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#FFCDD2" BorderThickness="2" CornerRadius="4"
                                Padding="10" Margin="5" Background="White">
                            <StackPanel>
                                <TextBlock Text="Rows=4, Columns=2" FontWeight="Bold"
                                           Foreground="#C62828" Margin="0,0,0,8" />
                                <UniformGrid Rows="4" Columns="2" Height="100" Width="200">
                                    <Border Background="#42A5F5" CornerRadius="2" Margin="2">
                                        <TextBlock Text="1" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#66BB6A" CornerRadius="2" Margin="2">
                                        <TextBlock Text="2" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FFA726" CornerRadius="2" Margin="2">
                                        <TextBlock Text="3" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#EF5350" CornerRadius="2" Margin="2">
                                        <TextBlock Text="4" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#AB47BC" CornerRadius="2" Margin="2">
                                        <TextBlock Text="5" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#26A69A" CornerRadius="2" Margin="2">
                                        <TextBlock Text="6" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#FF7043" CornerRadius="2" Margin="2">
                                        <TextBlock Text="7" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border Background="#5C6BC0" CornerRadius="2" Margin="2">
                                        <TextBlock Text="8" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="💡 UniformGrid 关键要点" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="• 所有单元格大小完全相同，由面板总尺寸和行列数自动计算"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 元素按从左到右、从上到下的顺序依次填充"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 适合需要均匀排列的网格场景（色板、键盘、照片墙等）"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 相比 Grid，不需要手动指定每个元素的行列位置"
                               Foreground="#616161" Margin="0,2,0,0" />
                    <TextBlock Text="• 不设置 Rows/Columns 时，会自动计算行列数使单元格尽量接近正方形"
                               Foreground="#616161" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>