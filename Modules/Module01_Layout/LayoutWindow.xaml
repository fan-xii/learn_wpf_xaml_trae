<Window x:Class="LearnXaml.Modules.Module01_Layout.LayoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📐 XAML 布局基础" Height="720" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="← 返回主菜单" Style="{StaticResource DemoButton}"
                    Background="{StaticResource SecondaryBrush}"
                    Click="BackButton_Click" />
            <Border Width="48" Height="48" CornerRadius="6" Background="#FF4CAF50"
                    Margin="20,0,12,0">
                <TextBlock Text="📐" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="XAML 布局基础" Style="{StaticResource TitleText}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="MainListBox" Grid.Column="0"
                     SelectionChanged="MainTabControl_SelectionChanged"
                     Background="White"
                     BorderBrush="#E0E0E0"
                     BorderThickness="1">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="Padding" Value="16,12" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="BorderBrush" Value="#E0E0E0" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD" />
                                <Setter Property="Foreground" Value="#1565C0" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
                
                <ListBoxItem Tag="GridDemo">Grid 网格</ListBoxItem>
                <ListBoxItem Tag="StackPanelDemo">StackPanel 堆叠</ListBoxItem>
                <ListBoxItem Tag="DockPanelDemo">DockPanel 停靠</ListBoxItem>
                <ListBoxItem Tag="WrapPanelDemo">WrapPanel 环绕</ListBoxItem>
                <ListBoxItem Tag="CanvasDemo">Canvas 画布</ListBoxItem>
                <ListBoxItem Tag="UniformGridDemo">UniformGrid 均匀</ListBoxItem>
            </ListBox>

            <Frame x:Name="ContentFrame" Grid.Column="1"
                   NavigationUIVisibility="Hidden"
                   Margin="10,0,0,0" />
        </Grid>
    </Grid>
</Window>