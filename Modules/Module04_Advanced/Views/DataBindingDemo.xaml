<Page x:Class="LearnXaml.Modules.Module04_Advanced.Views.DataBindingDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module04_Advanced.Views"
      Title="数据绑定演示"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- ============ 标题 ============ -->
            <TextBlock Text="📊 数据绑定 (Data Binding) 详解" Style="{StaticResource TitleText}" />

            <!-- ============ 1. 绑定模式演示 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1. 绑定模式 (Binding Mode)" Style="{StaticResource SubTitleText}" />

                    <WrapPanel Margin="0,5">
                        <Border Background="#F3E5F5" CornerRadius="4" Padding="10,6" Margin="4"
                                BorderBrush="#CE93D8" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="OneWay" FontWeight="Bold" Foreground="#7B1FA2" />
                                <TextBlock Text="源→目标（只读）" FontSize="11" Foreground="#757575" />
                                <TextBox Text="{Binding CustomText, Mode=OneWay}"
                                         Width="200" Margin="0,4,0,0"
                                         IsReadOnly="True" Foreground="#7B1FA2" />
                            </StackPanel>
                        </Border>

                        <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="4"
                                BorderBrush="#81C784" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="TwoWay" FontWeight="Bold" Foreground="#2E7D32" />
                                <TextBlock Text="源↔目标（双向）" FontSize="11" Foreground="#757575" />
                                <TextBox Text="{Binding CustomText, Mode=TwoWay}"
                                         Width="200" Margin="0,4,0,0"
                                         Foreground="#2E7D32" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF3E0" CornerRadius="4" Padding="10,6" Margin="4"
                                BorderBrush="#FFB74D" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="OneTime" FontWeight="Bold" Foreground="#E65100" />
                                <TextBlock Text="仅初始化时加载" FontSize="11" Foreground="#757575" />
                                <TextBox Text="{Binding CustomText, Mode=OneTime}"
                                         Width="200" Margin="0,4,0,0"
                                         IsReadOnly="True" Foreground="#E65100" />
                            </StackPanel>
                        </Border>

                        <Border Background="#E3F2FD" CornerRadius="4" Padding="10,6" Margin="4"
                                BorderBrush="#64B5F6" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="OneWayToSource" FontWeight="Bold" Foreground="#1565C0" />
                                <TextBlock Text="目标→源（反向）" FontSize="11" Foreground="#757575" />
                                <TextBox Text="{Binding CustomText, Mode=OneWayToSource}"
                                         Width="200" Margin="0,4,0,0"
                                         Foreground="#1565C0" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ============ 2. ElementName 绑定 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. ElementName 绑定（元素间绑定）" Style="{StaticResource SubTitleText}" />

                    <TextBlock Text="拖动滑块改变文字大小和颜色预览：" Margin="0,0,0,8" Foreground="#616161" />

                    <!-- 颜色选择器：RGB 滑块 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="R:" Width="20" VerticalAlignment="Center" Foreground="#F44336" />
                        <Slider x:Name="RedSlider" Minimum="0" Maximum="255" Value="33"
                                Width="200" Margin="4,0" />
                        <TextBlock Text="{Binding ElementName=RedSlider, Path=Value, StringFormat={}{0:F0}}"
                                   Width="30" VerticalAlignment="Center" Foreground="#F44336" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="G:" Width="20" VerticalAlignment="Center" Foreground="#4CAF50" />
                        <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" Value="150"
                                Width="200" Margin="4,0" />
                        <TextBlock Text="{Binding ElementName=GreenSlider, Path=Value, StringFormat={}{0:F0}}"
                                   Width="30" VerticalAlignment="Center" Foreground="#4CAF50" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="B:" Width="20" VerticalAlignment="Center" Foreground="#2196F3" />
                        <Slider x:Name="BlueSlider" Minimum="0" Maximum="255" Value="243"
                                Width="200" Margin="4,0" />
                        <TextBlock Text="{Binding ElementName=BlueSlider, Path=Value, StringFormat={}{0:F0}}"
                                   Width="30" VerticalAlignment="Center" Foreground="#2196F3" />
                    </StackPanel>

                    <!-- 实时预览 -->
                    <Border x:Name="ColorPreview" Width="200" Height="60" CornerRadius="6" Margin="0,10,0,0">
                        <Border.Background>
                            <SolidColorBrush>
                                <SolidColorBrush.Color>
                                    <MultiBinding Converter="{StaticResource RgbToColorConverter}">
                                        <Binding ElementName="RedSlider" Path="Value" />
                                        <Binding ElementName="GreenSlider" Path="Value" />
                                        <Binding ElementName="BlueSlider" Path="Value" />
                                    </MultiBinding>
                                </SolidColorBrush.Color>
                            </SolidColorBrush>
                        </Border.Background>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                                   FontSize="16" FontWeight="Bold" Foreground="White">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="RGB({0:F0}, {1:F0}, {2:F0})">
                                    <Binding ElementName="RedSlider" Path="Value" />
                                    <Binding ElementName="GreenSlider" Path="Value" />
                                    <Binding ElementName="BlueSlider" Path="Value" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>

                    <!-- 文字大小预览 -->
                    <TextBlock Text="文字大小预览" Margin="0,12,0,4" Foreground="#616161" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="字号:" VerticalAlignment="Center" />
                        <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="48" Value="16"
                                Width="200" Margin="6,0" />
                        <TextBlock Text="{Binding ElementName=FontSizeSlider, Path=Value, StringFormat={}{0:F0} pt}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,8,0,0"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <TextBlock Text="实时预览文字效果 Hello WPF!"
                                   FontSize="{Binding ElementName=FontSizeSlider, Path=Value}" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============ 3. RelativeSource 绑定 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. RelativeSource 绑定" Style="{StaticResource SubTitleText}" />

                    <TextBlock Text="Self（自身属性绑定）：" FontWeight="SemiBold" Margin="0,6,0,2" Foreground="#424242" />
                    <TextBox x:Name="SelfToolTipBox" Width="260" Text="Hello WPF!">
                        <TextBox.ToolTip>
                            <Binding RelativeSource="{RelativeSource Self}" Path="Text" StringFormat="ToolTip 显示: {0}" />
                        </TextBox.ToolTip>
                    </TextBox>
                    <TextBlock Text="💡 修改上方文字后悬停，ToolTip 会同步更新（RelativeSource Self 绑定）"
                               FontSize="11" Foreground="#757575" Margin="0,4,0,0" />

                    <TextBlock Text="FindAncestor（查找父级元素）：" FontWeight="SemiBold" Margin="0,12,0,2" Foreground="#424242" />
                    <Border BorderBrush="#E0E0E0" BorderThickness="2" CornerRadius="6" Padding="12"
                            Background="#FAFAFA" x:Name="ParentBorder" Tag="这是父级 Border 的 Tag 属性">
                        <StackPanel>
                            <TextBlock Text="父级 Border (Tag 在 ToolTip 中显示)" />
                            <TextBlock Text="将鼠标悬停在下面按钮上查看 FindAncestor 效果"
                                       FontSize="11" Foreground="#757575" Margin="0,2,0,6" />
                            <Button Content="悬停查看父级 Tag"
                                    Width="180"
                                    ToolTip="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Border}}, Path=Tag}" />
                            <Button Content="悬停查看父级 Name"
                                    Width="180" Margin="0,4,0,0"
                                    ToolTip="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Border}}, Path=Name}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="TemplatedParent（模板父级绑定）：" FontWeight="SemiBold" Margin="0,12,0,2" Foreground="#424242" />
                    <TextBlock Text="在 ControlTemplate 中使用，见下方自定义按钮示例" FontSize="11" Foreground="#757575" />
                </StackPanel>
            </Border>

            <!-- ============ 4. UpdateSourceTrigger ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="4. UpdateSourceTrigger 更新触发时机" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="PropertyChanged（即时更新）" FontWeight="SemiBold"
                                       Foreground="#2E7D32" Margin="0,0,0,4" />
                            <TextBox Text="{Binding CustomText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,2" />
                            <TextBlock Text="输入内容立即同步↓" FontSize="10" Foreground="#757575" />
                            <TextBlock Text="{Binding CustomText}" FontSize="12" Foreground="#2E7D32"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="LostFocus（失去焦点更新）" FontWeight="SemiBold"
                                       Foreground="#E65100" Margin="0,0,0,4" />
                            <TextBox Text="{Binding CustomText, UpdateSourceTrigger=LostFocus}"
                                     Margin="0,2" />
                            <TextBlock Text="按 Tab 失去焦点后同步↓" FontSize="10" Foreground="#757575" />
                            <TextBlock Text="{Binding CustomText}" FontSize="12" Foreground="#E65100"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="4">
                            <TextBlock Text="Explicit（手动调用更新）" FontWeight="SemiBold"
                                       Foreground="#1565C0" Margin="0,0,0,4" />
                            <TextBox x:Name="ExplicitTextBox"
                                     Text="{Binding CustomText, UpdateSourceTrigger=Explicit}"
                                     Margin="0,2" />
                            <Button Content="点击手动更新" Click="OnExplicitUpdateClick"
                                    Width="120" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding CustomText}" FontSize="12" Foreground="#1565C0"
                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ 5. StringFormat / Fallback / Null 值 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="5. StringFormat、FallbackValue 与 TargetNullValue" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="StringFormat 格式化：" FontWeight="SemiBold" Foreground="#424242" />
                            <TextBlock Text="Slider值: 50" />
                            <Slider x:Name="FormatSlider" Minimum="0" Maximum="100" Value="50" Width="200" />
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Text>
                                    <Binding ElementName="FormatSlider" Path="Value"
                                             StringFormat="当前值: {0:F2}%" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock>
                                <TextBlock.Text>
                                    <Binding ElementName="FormatSlider" Path="Value"
                                             StringFormat="价格: ¥{0:F0}" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock>
                                <TextBlock.Text>
                                    <Binding ElementName="FormatSlider" Path="Value"
                                             StringFormat="十六进制: 0x{0:X2}" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="FallbackValue（绑定失败时）：" FontWeight="SemiBold" Foreground="#424242" />
                            <TextBlock Text="{Binding NonExistentProperty, FallbackValue=【默认回退值】}"
                                       Foreground="#F44336" Margin="0,4" />
                            <TextBlock Text="{Binding AnotherMissing, FallbackValue=绑定失败-使用此值}"
                                       Foreground="#FF9800" Margin="0,4" />

                            <TextBlock Text="TargetNullValue（绑定为null时）：" FontWeight="SemiBold"
                                       Foreground="#424242" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding NullProperty, TargetNullValue=【值为空】}"
                                       Foreground="#2196F3" Margin="0,4" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ 6. 文字实时预览 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="6. 综合示例：文字实时预览" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：输入控件 -->
                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="输入文字：" Margin="0,0,0,2" />
                            <TextBox x:Name="LiveTextInput" Text="Hello WPF 数据绑定!"
                                     TextWrapping="Wrap" Height="60" AcceptsReturn="True" />

                            <TextBlock Text="选择颜色：" Margin="0,8,0,2" />
                            <ComboBox x:Name="ColorCombo" SelectedIndex="0">
                                <ComboBoxItem Content="黑色" Tag="Black" />
                                <ComboBoxItem Content="蓝色" Tag="Blue" />
                                <ComboBoxItem Content="绿色" Tag="Green" />
                                <ComboBoxItem Content="橙色" Tag="Orange" />
                                <ComboBoxItem Content="红色" Tag="Red" />
                                <ComboBoxItem Content="紫色" Tag="Purple" />
                            </ComboBox>

                            <TextBlock Text="字号：" Margin="0,8,0,2" />
                            <Slider x:Name="LiveSizeSlider" Minimum="8" Maximum="48" Value="18" />
                            <TextBlock Text="{Binding ElementName=LiveSizeSlider, Path=Value, StringFormat=字号: {0:F0} pt}"
                                       FontSize="11" Foreground="#757575" />

                            <CheckBox x:Name="BoldCheck" Content="加粗" Margin="0,8,0,2" />
                            <CheckBox x:Name="ItalicCheck" Content="斜体" />
                        </StackPanel>

                        <!-- 右侧：预览 -->
                        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10,4"
                                BorderBrush="#E0E0E0" BorderThickness="1" MinHeight="150">
                            <TextBlock x:Name="LivePreview"
                                       Text="{Binding ElementName=LiveTextInput, Path=Text}"
                                       FontSize="{Binding ElementName=LiveSizeSlider, Path=Value}"
                                       Foreground="{Binding ElementName=ColorCombo, Path=SelectedItem.Tag}"
                                       FontWeight="{Binding ElementName=BoldCheck, Path=IsChecked,
                                            FallbackValue=Normal}"
                                       FontStyle="{Binding ElementName=ItalicCheck, Path=IsChecked,
                                            FallbackValue=Normal}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>