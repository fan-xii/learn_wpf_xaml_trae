<Page x:Class="LearnXaml.Modules.Module04_Advanced.Views.ConverterDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module04_Advanced.Views"
      xmlns:conv="clr-namespace:LearnXaml.Converters"
      Title="值转换器演示"
      Background="{StaticResource BgBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:AgeToColorConverter x:Key="AgeToColor" />
        <conv:PriceToBackgroundConverter x:Key="PriceToBg" />
        <conv:StringNotEmptyConverter x:Key="StringNotEmpty" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- ============ 标题 ============ -->
            <TextBlock Text="🔄 值转换器 (Value Converters)" Style="{StaticResource TitleText}" />

            <!-- ============ 什么是值转换器 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="什么是值转换器？" Style="{StaticResource SubTitleText}" />
                    <Border Background="#E8EAF6" CornerRadius="4" Padding="12">
                        <StackPanel>
                            <TextBlock Text="💡 IValueConverter 接口：实现数据绑定时的值转换逻辑"
                                       FontWeight="Bold" Foreground="#3F51B5" />
                            <TextBlock Text="· Convert: 源→目标 (Model→View)" Foreground="#424242" Margin="0,4,0,0" />
                            <TextBlock Text="· ConvertBack: 目标→源 (View→Model)" Foreground="#424242" />
                            <TextBlock Text="· ConverterParameter: 传递额外参数" Foreground="#424242" />
                            <TextBlock Text="· 所有转换器位于 LearnXaml.Converters 命名空间"
                                       Foreground="#757575" FontSize="11" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============ 1. BoolToVisibilityConverter ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1. BoolToVisibilityConverter（布尔值→可见性）" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <CheckBox x:Name="ShowDetailCheck" Content="显示详细信息" IsChecked="True" />
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="10" Margin="0,8,0,0"
                                    Visibility="{Binding ElementName=ShowDetailCheck, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="✅ 这是详细信息内容" Foreground="#2E7D32" FontWeight="SemiBold" />
                                    <TextBlock Text="勾选/取消勾选 CheckBox 来控制显示" Foreground="#616161"
                                               FontSize="11" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4">
                            <CheckBox x:Name="HideDetailCheck" Content="隐藏警告信息" IsChecked="False" />
                            <Border Background="#FFEBEE" CornerRadius="4" Padding="10" Margin="0,8,0,0"
                                    Visibility="{Binding ElementName=HideDetailCheck, Path=IsChecked, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                <StackPanel>
                                    <TextBlock Text="⚠️ 警告：请先保存数据" Foreground="#C62828" FontWeight="SemiBold" />
                                    <TextBlock Text="使用 ConverterParameter=Invert 反转逻辑"
                                               Foreground="#616161" FontSize="11" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ 2. Product List with Multiple Converters ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. 产品列表 - 多种转换器综合应用" Style="{StaticResource SubTitleText}" />

                    <ListView ItemsSource="{Binding Products}" MaxHeight="300">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="40"
                                                DisplayMemberBinding="{Binding Id}" />
                                <GridViewColumn Header="名称" Width="110"
                                                DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="类别" Width="80"
                                                DisplayMemberBinding="{Binding Category}" />
                                <GridViewColumn Header="价格" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Price, StringFormat=¥{0:N0}}"
                                                       Foreground="{Binding Price, Converter={StaticResource PriceToBg}}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="库存" Width="60"
                                                DisplayMemberBinding="{Binding Stock}" />
                                <GridViewColumn Header="库存状态" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="10" Height="10" CornerRadius="5" Margin="0,0,6,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Stock}" Value="0">
                                                                    <Setter Property="Background" Value="#F44336" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Stock}" Value="1">
                                                                    <Setter Property="Background" Value="#FF9800" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="充足" />
                                                            <Setter Property="Foreground" Value="#4CAF50" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Stock}" Value="0">
                                                                    <Setter Property="Text" Value="缺货" />
                                                                    <Setter Property="Foreground" Value="#F44336" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="高价" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Price}"
                                                                         Value="6999">
                                                                <Setter Property="Text" Value="💰" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#757575">
                        💡 价格颜色由 PriceToBackgroundConverter 控制：&lt;100 绿色 | 100-500 黄色 | &gt;500 红色
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ============ 3. AgeToColorConverter ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. AgeToColorConverter（年龄→颜色）" Style="{StaticResource SubTitleText}" />

                    <WrapPanel>
                        <Border Background="White" CornerRadius="4" Padding="10" Margin="4"
                                BorderBrush="#E0E0E0" BorderThickness="1" Width="140">
                            <StackPanel>
                                <TextBlock Text="学生年龄: 16" FontWeight="SemiBold" />
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,6,0,0">
                                    <Border.Background>
                                        <Binding Source="16" Converter="{StaticResource AgeToColor}" />
                                    </Border.Background>
                                    <TextBlock Text="16" Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" FontSize="12" />
                                </Border>
                                <TextBlock Text="青少年 (绿)" FontSize="10" Foreground="#757575"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="4" Padding="10" Margin="4"
                                BorderBrush="#E0E0E0" BorderThickness="1" Width="140">
                            <StackPanel>
                                <TextBlock Text="学生年龄: 22" FontWeight="SemiBold" />
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,6,0,0">
                                    <Border.Background>
                                        <Binding Source="22" Converter="{StaticResource AgeToColor}" />
                                    </Border.Background>
                                    <TextBlock Text="22" Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" FontSize="12" />
                                </Border>
                                <TextBlock Text="青年 (蓝)" FontSize="10" Foreground="#757575"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="4" Padding="10" Margin="4"
                                BorderBrush="#E0E0E0" BorderThickness="1" Width="140">
                            <StackPanel>
                                <TextBlock Text="学生年龄: 30" FontWeight="SemiBold" />
                                <Border Width="40" Height="40" CornerRadius="20" Margin="0,6,0,0">
                                    <Border.Background>
                                        <Binding Source="30" Converter="{StaticResource AgeToColor}" />
                                    </Border.Background>
                                    <TextBlock Text="30" Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" FontSize="12" />
                                </Border>
                                <TextBlock Text="成年 (橙)" FontSize="10" Foreground="#757575"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ============ 4. StringNotEmptyConverter ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="4. StringNotEmptyConverter（非空字符串判断）" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="输入内容后显示提示：" FontWeight="SemiBold" Foreground="#424242" />
                            <TextBox x:Name="NotEmptyInput" Width="200" Margin="0,6,0,0" />
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="8,4" Margin="0,6,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=NotEmptyInput, Path=Text, Converter={StaticResource StringNotEmpty}}"
                                                         Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Foreground="#2E7D32">
                                    <TextBlock.Text>
                                        <Binding ElementName="NotEmptyInput" Path="Text"
                                                 StringFormat="✅ 已输入: 「{0}」" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="输入为空时显示警告：" FontWeight="SemiBold" Foreground="#424242" />
                            <TextBox x:Name="EmptyWarning" Width="200" Margin="0,6,0,0" Text="预填内容" />
                            <Border Background="#FFEBEE" CornerRadius="4" Padding="8,4" Margin="0,6,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=EmptyWarning, Path=Text, Converter={StaticResource StringNotEmpty}}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="⚠️ 输入不能为空！" Foreground="#C62828" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ 5. DataTrigger 条件格式 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="5. DataTrigger 条件格式化（不依赖转换器的替代方案）" Style="{StaticResource SubTitleText}" />

                    <TextBlock Text="使用 DataTrigger 根据 Stock 值改变行背景色：" FontWeight="SemiBold"
                               Foreground="#424242" Margin="0,0,0,6" />

                    <ListView ItemsSource="{Binding Products}" MaxHeight="220">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Stock}" Value="0">
                                        <Setter Property="Background" Value="#FFCDD2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="名称" Width="100"
                                                DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="类别" Width="80"
                                                DisplayMemberBinding="{Binding Category}" />
                                <GridViewColumn Header="价格" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Price, StringFormat=¥{0:N0}}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="库存" Width="60"
                                                DisplayMemberBinding="{Binding Stock}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="#757575">
                        💡 DataTrigger 无需编写 C# 转换器，直接在 XAML 中根据数据值切换样式
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>