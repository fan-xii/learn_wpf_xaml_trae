<Page x:Class="LearnXaml.Modules.Module04_Advanced.Views.CustomControlDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module04_Advanced.Views"
      Title="自定义控件演示"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- ============ 标题 ============ -->
            <TextBlock Text="🎛 自定义控件与依赖属性" Style="{StaticResource TitleText}" />

            <!-- ============ 1. RatingControl 使用演示 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1. 自定义 RatingControl（星级评分控件）" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="基本使用：" FontWeight="SemiBold" Foreground="#424242" />
                            <local:RatingControl x:Name="Rating1" Value="3" Margin="0,6,0,0" />
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Text>
                                    <Binding ElementName="Rating1" Path="Value" StringFormat="当前评分: {0} / 5" />
                                </TextBlock.Text>
                            </TextBlock>

                            <TextBlock Text="点击星星进行评分" FontSize="11" Foreground="#757575" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="双向绑定演示：" FontWeight="SemiBold" Foreground="#424242" />
                            <local:RatingControl x:Name="Rating2" Value="4" Margin="0,6,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="手动设置值: " VerticalAlignment="Center" />
                                <TextBox x:Name="RatingInput" Text="{Binding ElementName=Rating2, Path=Value, Mode=TwoWay}"
                                         Width="40" TextAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="输入 0-5 数字可反向更新星级" FontSize="11" Foreground="#757575" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ 2. 依赖属性说明 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. 依赖属性 (DependencyProperty) 详解" Style="{StaticResource SubTitleText}" />

                    <Border Background="#E3F2FD" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="💡 什么是依赖属性？" FontWeight="Bold" Foreground="#1565C0" />
                            <TextBlock Text="依赖属性是 WPF 属性系统的核心，提供以下能力："
                                       Margin="0,4,0,0" Foreground="#424242" />
                            <TextBlock Text="· 支持数据绑定 (Binding)" Foreground="#424242" />
                            <TextBlock Text="· 支持样式 (Style Setter)" Foreground="#424242" />
                            <TextBlock Text="· 支持动画 (Animation)" Foreground="#424242" />
                            <TextBlock Text="· 支持属性值继承 (Inherits)" Foreground="#424242" />
                            <TextBlock Text="· 支持属性变更回调 (PropertyChangedCallback)" Foreground="#424242" />
                        </StackPanel>
                    </Border>

                    <Border Background="#F5F5F5" CornerRadius="4" Padding="12">
                        <StackPanel>
                            <TextBlock Text="RatingControl 中的依赖属性定义：" FontWeight="SemiBold" Foreground="#424242"
                                       FontFamily="Consolas" />
                            <TextBlock Text="public static readonly DependencyProperty ValueProperty =" FontFamily="Consolas"
                                       Foreground="#616161" FontSize="12" />
                            <TextBlock Text="    DependencyProperty.Register(nameof(Value), typeof(int)," FontFamily="Consolas"
                                       Foreground="#616161" FontSize="12" Margin="20,0,0,0" />
                            <TextBlock Text="        typeof(RatingControl)," FontFamily="Consolas"
                                       Foreground="#616161" FontSize="12" Margin="20,0,0,0" />
                            <TextBlock Text="        new FrameworkPropertyMetadata(0," FontFamily="Consolas"
                                       Foreground="#616161" FontSize="12" Margin="20,0,0,0" />
                            <TextBlock Text="            FrameworkPropertyMetadataOptions.BindsTwoWayByDefault," FontFamily="Consolas"
                                       Foreground="#616161" FontSize="12" Margin="20,0,0,0" />
                            <TextBlock Text="            OnValueChanged));" FontFamily="Consolas"
                                       Foreground="#616161" FontSize="12" Margin="20,0,0,0" />

                            <TextBlock Text="关键参数说明：" FontWeight="SemiBold" Foreground="#424242" Margin="0,10,0,4" />
                            <TextBlock Text="· BindsTwoWayByDefault: 默认双向绑定" Foreground="#616161" FontSize="12" />
                            <TextBlock Text="· PropertyChangedCallback: 值变化时的回调方法" Foreground="#616161" FontSize="12" />
                            <TextBlock Text="· CoerceValueCallback: 强制值约束" Foreground="#616161" FontSize="12" />
                            <TextBlock Text="· ValidateValueCallback: 值验证" Foreground="#616161" FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ============ 3. 附加属性示例 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. 附加属性 (Attached Property) 示例" Style="{StaticResource SubTitleText}" />

                    <Border Background="#FFF8E1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="💡 附加属性：定义在某个类中但可以被其他类使用的属性" FontWeight="Bold"
                                       Foreground="#F57F17" />
                            <TextBlock Text="例如：Grid.Row、Canvas.Left、DockPanel.Dock 都是附加属性"
                                       Foreground="#424242" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="WPF 内置附加属性演示：" FontWeight="SemiBold" Foreground="#424242" />

                    <Border Background="White" CornerRadius="4" Padding="8" Margin="0,6,0,0"
                            BorderBrush="#E0E0E0" BorderThickness="1" Height="200">
                        <Grid ShowGridLines="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="#E3F2FD" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=0, Col=0" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Background="#FFF3E0" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=0, Col=1" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2" Background="#E8F5E9" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=0, Col=2" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Background="#F3E5F5" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=1, Col=0, ColSpan=2" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Background="#FFEBEE" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=1, Col=2" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Background="#E0F7FA" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=2, Col=0" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                    Background="#FFF9C4" CornerRadius="4" Margin="2">
                                <TextBlock Text="Row=2, Col=1, ColSpan=2" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="10" />
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock Text="Grid.Row 和 Grid.Column 是最常用的附加属性" FontSize="11"
                               Foreground="#757575" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- ============ 4. UserControl vs Custom Control ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="4. UserControl vs Custom Control 对比" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="📦 UserControl" FontWeight="Bold" FontSize="14" Foreground="#1565C0" />
                                <TextBlock Text="· 组合现有控件构建" Margin="0,4,0,0" Foreground="#424242" />
                                <TextBlock Text="· XAML + Code-Behind" Foreground="#424242" />
                                <TextBlock Text="· 快速开发，适合特定场景" Foreground="#424242" />
                                <TextBlock Text="· 难以更换外观模板" Foreground="#424242" />
                                <TextBlock Text="· 不可被继承替换" Foreground="#424242" />
                                <TextBlock Text="示例：RatingControl（本页）" Foreground="#1565C0"
                                           FontWeight="SemiBold" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="🎨 Custom Control" FontWeight="Bold" FontSize="14" Foreground="#E65100" />
                                <TextBlock Text="· 继承 Control 类" Margin="0,4,0,0" Foreground="#424242" />
                                <TextBlock Text="· Generic.xaml 定义默认样式" Foreground="#424242" />
                                <TextBlock Text="· 支持 TemplateBinding" Foreground="#424242" />
                                <TextBlock Text="· 可完全自定义外观" Foreground="#424242" />
                                <TextBlock Text="· 适合库/框架开发" Foreground="#424242" />
                                <TextBlock Text="示例：WPF 内置 Button, Slider" Foreground="#E65100"
                                           FontWeight="SemiBold" Margin="0,6,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>