<Page x:Class="LearnXaml.Modules.Module04_Advanced.Views.MvvmDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module04_Advanced.Views"
      xmlns:vm="clr-namespace:LearnXaml.ViewModels"
      xmlns:models="clr-namespace:LearnXaml.Models"
      Title="MVVM 模式演示"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- ============ 标题 ============ -->
            <TextBlock Text="🏗 MVVM (Model-View-ViewModel) 模式" Style="{StaticResource TitleText}" />

            <!-- ============ MVVM 架构说明 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="MVVM 三层架构" Style="{StaticResource SubTitleText}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="📦 Model (模型)" FontWeight="Bold" FontSize="14" Foreground="#1565C0" />
                                <TextBlock Text="· Student 类" Margin="0,4,0,0" Foreground="#424242" />
                                <TextBlock Text="· 数据实体定义" Foreground="#424242" />
                                <TextBlock Text="· 纯数据，不含逻辑" Foreground="#424242" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="🖥 View (视图)" FontWeight="Bold" FontSize="14" Foreground="#E65100" />
                                <TextBlock Text="· XAML 页面" Margin="0,4,0,0" Foreground="#424242" />
                                <TextBlock Text="· 只负责UI展示" Foreground="#424242" />
                                <TextBlock Text="· 不包含业务逻辑" Foreground="#424242" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="6" Padding="12" Margin="4">
                            <StackPanel>
                                <TextBlock Text="🧠 ViewModel" FontWeight="Bold" FontSize="14" Foreground="#2E7D32" />
                                <TextBlock Text="· StudentViewModel" Margin="0,4,0,0" Foreground="#424242" />
                                <TextBlock Text="· ObservableObject" Foreground="#424242" />
                                <TextBlock Text="· RelayCommand" Foreground="#424242" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ Master-Detail 布局 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="Master-Detail 学生管理系统" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- ===== 左侧：学生列表 ===== -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📋 学生列表" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#424242" />

                            <!-- 过滤器 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="搜索：" VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding NameFilter, UpdateSourceTrigger=PropertyChanged}"
                                         Width="160" />
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding Students}"
                                      SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      Height="320"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40" />
                                    <DataGridTextColumn Header="姓名" Binding="{Binding Name, Mode=TwoWay}" Width="80" />
                                    <DataGridTextColumn Header="年龄" Binding="{Binding Age, Mode=TwoWay}" Width="50" />
                                    <DataGridTextColumn Header="年级" Binding="{Binding Grade, Mode=TwoWay}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- 操作按钮 -->
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="➕ 添加" Style="{StaticResource DemoButton}"
                                        Background="{StaticResource AccentBrush}"
                                        Command="{Binding AddStudentCommand}" />
                                <Button Content="🗑 删除" Style="{StaticResource DemoButton}"
                                        Background="{StaticResource DangerBrush}"
                                        Command="{Binding DeleteStudentCommand}" />
                                <Button Content="🧹 清空" Style="{StaticResource DemoButton}"
                                        Background="#757575"
                                        Command="{Binding ClearCommand}" />
                            </WrapPanel>
                        </StackPanel>

                        <GridSplitter Grid.Column="1" Width="3" Background="#E0E0E0"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                        <!-- ===== 右侧：详情编辑 ===== -->
                        <StackPanel Grid.Column="2" Margin="15,0,0,0">
                            <TextBlock Text="📝 详细信息" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#424242" />

                            <Border Background="White" CornerRadius="6" Padding="15"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="姓　名：" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStudent.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding SelectedStudent, Converter={StaticResource NotNullToBoolConverter}}" />
                                    </Grid>

                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="年　龄：" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStudent.Age, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="年　级：" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStudent.Grade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="邮　箱：" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding SelectedStudent.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <CheckBox Content="已注册"
                                              IsChecked="{Binding SelectedStudent.IsEnrolled, Mode=TwoWay}"
                                              Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- 选中状态提示 -->
                            <Border Background="#FFF9C4" CornerRadius="4" Padding="10,6" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock FontSize="12" Foreground="#F57F17">
                                        <TextBlock.Text>
                                            <Binding Path="SelectedStudent" StringFormat="当前选中: {0}">
                                                <Binding.FallbackValue>请从列表中选择一个学生</Binding.FallbackValue>
                                            </Binding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock FontSize="11" Foreground="#757575" Margin="0,2,0,0">
                                        <TextBlock.Text>
                                            <Binding Path="Students.Count" StringFormat="共有 {0} 名学生" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- 只读信息展示 -->
                            <Border Background="#E8F5E9" CornerRadius="4" Padding="10,6" Margin="0,6,0,0">
                                <TextBlock FontSize="12" Foreground="#2E7D32">
                                    💡 提示：在 DataGrid 中双击单元格可直接编辑数据（TwoWay 绑定）
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ 绑定通知演示 ============ -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="属性变更通知 (PropertyChanged) 演示" Style="{StaticResource SubTitleText}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="4">
                            <TextBlock Text="实时搜索过滤器：" FontWeight="SemiBold" Foreground="#424242" />
                            <TextBox Text="{Binding NameFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4" />
                            <TextBlock Margin="0,4,0,0">
                                <TextBlock.Text>
                                    <Binding Path="NameFilter" StringFormat="当前过滤关键词: 「{0}」">
                                        <Binding.FallbackValue>当前过滤关键词: （无）</Binding.FallbackValue>
                                    </Binding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="4">
                            <TextBlock Text="学生总数实时更新：" FontWeight="SemiBold" Foreground="#424242" />
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,10">
                                <TextBlock.Text>
                                    <Binding Path="Students.Count" StringFormat="{}{0}" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="名学生" HorizontalAlignment="Center" Foreground="#757575" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>