<Page x:Class="LearnXaml.Modules.Module02_Controls.Views.ListControlsDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module02_Controls.Views"
      Title="列表控件"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📋 ListBox / ListView / ComboBox" Style="{StaticResource TitleText}" />
            <TextBlock Text="列表控件用于展示数据集合。ListBox 简单灵活，ListView 支持多列 GridView 显示。"
                       Foreground="#757575" Margin="0,0,0,20" FontSize="14" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1. ListBox - 基础列表" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="ListBox 通过 ItemsSource 绑定数据集合，支持 SelectionMode 控制选择模式。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="单选模式 (SelectionMode=Single):" FontSize="13"
                                       Foreground="#616161" Margin="0,0,0,4" />
                            <ListBox x:Name="LstSingle" Width="260" Height="150"
                                     SelectionMode="Single"
                                     SelectionChanged="LstSingle_SelectionChanged">
                                <ListBoxItem Content="🍎 苹果" />
                                <ListBoxItem Content="🍌 香蕉" />
                                <ListBoxItem Content="🍊 橙子" />
                                <ListBoxItem Content="🍇 葡萄" />
                                <ListBoxItem Content="🍓 草莓" />
                                <ListBoxItem Content="🥝 猕猴桃" />
                            </ListBox>
                            <TextBlock x:Name="TxtSingleSelect" Text="请选择一个水果" FontSize="12"
                                       Foreground="{StaticResource PrimaryBrush}" Margin="0,3,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="多选模式 (SelectionMode=Multiple):" FontSize="13"
                                       Foreground="#616161" Margin="0,0,0,4" />
                            <ListBox x:Name="LstMultiple" Width="260" Height="150"
                                     SelectionMode="Multiple"
                                     SelectionChanged="LstMultiple_SelectionChanged">
                                <ListBoxItem Content="📚 阅读" />
                                <ListBoxItem Content="🎵 音乐" />
                                <ListBoxItem Content="🏃 运动" />
                                <ListBoxItem Content="🎮 游戏" />
                                <ListBoxItem Content="🎨 绘画" />
                                <ListBoxItem Content="✈ 旅行" />
                            </ListBox>
                            <TextBlock x:Name="TxtMultiSelect" Text="请选择你的爱好（可多选）" FontSize="12"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. ListBox - 自定义 ItemTemplate" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="通过 ItemTemplate 自定义每个列表项的显示样式，支持数据绑定。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <ListBox x:Name="LstStudents" Width="500" Height="200"
                             SelectionChanged="LstStudents_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="2" CornerRadius="4"
                                        Background="#F5F5F5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Id}" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       FontSize="14" />
                                            <TextBlock Text="{Binding Email}" FontSize="11"
                                                       Foreground="#9E9E9E" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Age, StringFormat={}{0}岁}"
                                                   VerticalAlignment="Center" Foreground="#616161" />
                                        <TextBlock Grid.Column="3" Text="{Binding Grade}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="TxtStudentSelect" Text="请选择一个学生查看详情" FontSize="13"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. ListBox - 分组 (GroupStyle)" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="使用 CollectionViewSource 和 GroupStyle 实现按类别分组显示。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <ListBox x:Name="LstGrouped" Width="500" Height="200">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                   FontSize="14" Foreground="White"
                                                   Background="{StaticResource PrimaryBrush}"
                                                   Padding="8,4" Margin="2,4,2,0" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="13" Margin="20,3,0,3" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="4. ListView - GridView 多列视图" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="ListView + GridView 实现类似表格的多列数据显示，支持列排序和灵活的列模板。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <ListView x:Name="LvStudents" Width="650" Height="200"
                              SelectionChanged="LvStudents_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50"
                                                DisplayMemberBinding="{Binding Id}" />
                                <GridViewColumn Header="姓名" Width="100"
                                                DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="年龄" Width="60"
                                                DisplayMemberBinding="{Binding Age}" />
                                <GridViewColumn Header="年级" Width="80"
                                                DisplayMemberBinding="{Binding Grade}" />
                                <GridViewColumn Header="邮箱" Width="180"
                                                DisplayMemberBinding="{Binding Email}" />
                                <GridViewColumn Header="状态" Width="80">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Foreground="{Binding IsEnrolled,
                                                           Converter={x:Static local:ListControlsDemo.IsEnrolledConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="未注册" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnrolled}" Value="True">
                                                                <Setter Property="Text" Value="已注册" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock x:Name="TxtListViewSelect" Text="ListView 支持列标题点击排序" FontSize="12"
                               Foreground="#9E9E9E" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="5. ComboBox 数据绑定" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="ComboBox 可以通过 ItemsSource 绑定数据集合，使用 DisplayMemberPath 指定显示字段。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <TextBlock Text="选择学生:" FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                    <ComboBox x:Name="CboStudent" Width="300" Height="28"
                              IsReadOnly="True" DisplayMemberPath="Name"
                              SelectionChanged="CboStudent_SelectionChanged" />
                    <TextBlock x:Name="TxtComboSelect" Text="请选择" FontSize="13"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>