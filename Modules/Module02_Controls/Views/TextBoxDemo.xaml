<Page x:Class="LearnXaml.Modules.Module02_Controls.Views.TextBoxDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module02_Controls.Views"
      Title="TextBox 文本控件"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📝 TextBox / PasswordBox / RichTextBox" Style="{StaticResource TitleText}" />
            <TextBlock Text="文本输入控件是用户输入数据的基础。TextBox 用于单行/多行文本，PasswordBox 用于密码输入，RichTextBox 用于富文本。"
                       Foreground="#757575" Margin="0,0,0,20" FontSize="14" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1. TextBox 基础属性" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="常用属性: Text, MaxLength, TextWrapping, AcceptsReturn, IsReadOnly, CharacterCasing"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="单行文本 (MaxLength=20):" FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtSingle" MaxLength="20" Width="280" Height="28"
                                     Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"
                                     TextChanged="TxtSingle_TextChanged" />
                            <TextBlock x:Name="TxtCharCount" Text="0 / 20 字符" FontSize="12"
                                       Foreground="#9E9E9E" Margin="0,3,0,15" />

                            <TextBlock Text="只读 TextBox:" FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                            <TextBox Text="此文本框为只读，不可编辑" IsReadOnly="True" Width="280" Height="28"
                                     Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"
                                     Background="#F5F5F5" Foreground="#9E9E9E" />

                            <TextBlock Text="大写转换 (CharacterCasing=Upper):" FontSize="13"
                                       Foreground="#616161" Margin="0,12,0,4" />
                            <TextBox CharacterCasing="Upper" Width="280" Height="28"
                                     Padding="5" BorderBrush="#BDBDBD" BorderThickness="1" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="多行文本 (TextWrapping=Wrap, AcceptsReturn=True):"
                                       FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtMulti" TextWrapping="Wrap" AcceptsReturn="True"
                                     Width="280" Height="120" Padding="5"
                                     BorderBrush="#BDBDBD" BorderThickness="1"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="在这里输入多行文本...&#x0a;每行都可以换行。" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. PasswordBox 密码框" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="PasswordBox 专门用于密码输入，字符自动掩码显示。支持 PasswordChar 自定义掩码字符。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="默认密码框 (● 掩码):" FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                            <PasswordBox x:Name="PwdBox" Width="280" Height="28"
                                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1"
                                         PasswordChanged="PwdBox_PasswordChanged" />
                            <TextBlock x:Name="TxtPwdLength" Text="密码长度: 0" FontSize="12"
                                       Foreground="#9E9E9E" Margin="0,3,0,15" />

                            <TextBlock Text="自定义掩码字符 (*):" FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                            <PasswordBox PasswordChar="*" Width="280" Height="28"
                                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="带 MaxLength 的密码框:" FontSize="13" Foreground="#616161" Margin="0,0,0,4" />
                            <PasswordBox MaxLength="6" Width="280" Height="28"
                                         Padding="5" BorderBrush="#BDBDBD" BorderThickness="1" />
                            <TextBlock Text="最多6位（如支付密码）" FontSize="12" Foreground="#9E9E9E" Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. 带 Placeholder 水印效果的 TextBox" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="通过叠加 TextBlock 模拟 Placeholder 效果，聚焦或输入文字后水印消失。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <Grid Width="350" Margin="0,0,0,10">
                        <TextBox x:Name="TxtPlaceholder" Height="32"
                                 Padding="8,6" BorderBrush="#BDBDBD" BorderThickness="1"
                                 TextChanged="TxtPlaceholder_TextChanged" />
                        <TextBlock x:Name="TxtWatermark" Text="请输入用户名..."
                                   IsHitTestVisible="False"
                                   Foreground="#BDBDBD" FontSize="14"
                                   Margin="10,7,0,0" />
                    </Grid>

                    <Grid Width="350">
                        <TextBox x:Name="TxtPlaceholder2" Height="32"
                                 Padding="8,6" BorderBrush="#BDBDBD" BorderThickness="1"
                                 TextChanged="TxtPlaceholder2_TextChanged" />
                        <TextBlock x:Name="TxtWatermark2" Text="请输入邮箱地址..."
                                   IsHitTestVisible="False"
                                   Foreground="#BDBDBD" FontSize="14"
                                   Margin="10,7,0,0" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="4. RichTextBox 富文本框" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="RichTextBox 支持富文本格式，可嵌入 FlowDocument，支持不同字体、颜色、加粗等。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <RichTextBox x:Name="RichTextBox" Height="100" Width="600"
                                 BorderBrush="#BDBDBD" BorderThickness="1"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,5">
                        <FlowDocument>
                            <Paragraph>
                                <Bold>RichTextBox</Bold> 支持
                                <Span Foreground="Red">彩色文字</Span>、
                                <Italic>斜体</Italic>、
                                <Underline>下划线</Underline>等多种格式。
                            </Paragraph>
                            <Paragraph>
                                你可以选中文字，使用快捷键 Ctrl+B 加粗、Ctrl+I 斜体、Ctrl+U 下划线。
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                    <TextBlock Text="提示：选中文字后按 Ctrl+B/I/U 可格式化文本" FontSize="12" Foreground="#9E9E9E" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="5. 多行文本编辑器示例" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="模拟一个简单的文本编辑器：TextWrapping=Wrap, AcceptsReturn=True, 带字符统计。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="字符数: " FontSize="13" Foreground="#616161" />
                        <TextBlock x:Name="TxtEditorCount" Text="0" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />
                        <TextBlock Text="  行数: " FontSize="13" Foreground="#616161" />
                        <TextBlock x:Name="TxtLineCount" Text="0" FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                    <TextBox x:Name="TxtEditor" TextWrapping="Wrap" AcceptsReturn="True"
                             Height="150" Width="600" Padding="8"
                             BorderBrush="#BDBDBD" BorderThickness="1"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="TxtEditor_TextChanged"
                             SpellCheck.IsEnabled="True" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>