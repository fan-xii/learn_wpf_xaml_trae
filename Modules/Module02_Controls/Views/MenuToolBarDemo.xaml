<Page x:Class="LearnXaml.Modules.Module02_Controls.Views.MenuToolBarDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module02_Controls.Views"
      Title="菜单与工具栏"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📂 Menu / ToolBar / StatusBar" Style="{StaticResource TitleText}" />
            <TextBlock Text="Menu、ToolBar 和 StatusBar 是构建应用界面的标准组件，组合使用可以模拟完整的应用外壳。"
                       Foreground="#757575" Margin="0,0,0,20" FontSize="14" />

            <Border Style="{StaticResource SectionBorder}" Padding="0">
                <StackPanel>
                    <TextBlock Text="1. 完整应用外壳演示" Style="{StaticResource SubTitleText}" Margin="15,15,15,5" />
                    <TextBlock Text="下方模拟了一个包含菜单栏、工具栏和状态栏的完整应用程序界面。"
                               Foreground="#757575" FontSize="13" Margin="15,0,15,10" />

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" Margin="15" CornerRadius="6" Background="White">
                        <DockPanel>
                            <Menu DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <MenuItem Header="📄 文件(_F)">
                                    <MenuItem Header="📝 新建(_N)" Click="FileNew_Click" InputGestureText="Ctrl+N" />
                                    <MenuItem Header="📂 打开(_O)" Click="FileOpen_Click" InputGestureText="Ctrl+O" />
                                    <Separator />
                                    <MenuItem Header="💾 保存(_S)" Click="FileSave_Click" InputGestureText="Ctrl+S" />
                                    <MenuItem Header="💾 另存为(_A)..." Click="FileSaveAs_Click" />
                                    <Separator />
                                    <MenuItem Header="📋 打印(_P)" Click="FilePrint_Click" />
                                    <Separator />
                                    <MenuItem Header="🚪 退出(_X)" Click="FileExit_Click" />
                                </MenuItem>

                                <MenuItem Header="✏ 编辑(_E)">
                                    <MenuItem Header="↩ 撤销(_U)" Click="EditUndo_Click" InputGestureText="Ctrl+Z" />
                                    <MenuItem Header="↪ 重做(_R)" Click="EditRedo_Click" InputGestureText="Ctrl+Y" />
                                    <Separator />
                                    <MenuItem Header="📋 剪切(_T)" Click="EditCut_Click" InputGestureText="Ctrl+X" />
                                    <MenuItem Header="📋 复制(_C)" Click="EditCopy_Click" InputGestureText="Ctrl+C" />
                                    <MenuItem Header="📋 粘贴(_P)" Click="EditPaste_Click" InputGestureText="Ctrl+V" />
                                    <Separator />
                                    <MenuItem Header="🔍 查找(_F)" Click="EditFind_Click" InputGestureText="Ctrl+F" />
                                    <MenuItem Header="🔄 替换(_R)" Click="EditReplace_Click" InputGestureText="Ctrl+H" />
                                </MenuItem>

                                <MenuItem Header="👁 视图(_V)">
                                    <MenuItem x:Name="MnuToolbar" Header="✔ 工具栏(_T)" IsCheckable="True"
                                              IsChecked="True" Click="MnuToolbar_Click" />
                                    <MenuItem x:Name="MnuStatusBar" Header="✔ 状态栏(_S)" IsCheckable="True"
                                              IsChecked="True" Click="MnuStatusBar_Click" />
                                    <Separator />
                                    <MenuItem Header="🔤 字体大小">
                                        <MenuItem Header="小" Click="FontSize_Click" Tag="Small" />
                                        <MenuItem Header="中" Click="FontSize_Click" Tag="Medium" />
                                        <MenuItem Header="大" Click="FontSize_Click" Tag="Large" />
                                    </MenuItem>
                                    <MenuItem Header="🎨 主题">
                                        <MenuItem x:Name="MnuLight" Header="✔ 浅色" Click="Theme_Click" Tag="Light" />
                                        <MenuItem x:Name="MnuDark" Header="深色" Click="Theme_Click" Tag="Dark" />
                                    </MenuItem>
                                </MenuItem>

                                <MenuItem Header="❓ 帮助(_H)">
                                    <MenuItem Header="📖 帮助文档(_H)" Click="HelpDoc_Click" />
                                    <MenuItem Header="🔗 在线资源(_O)" Click="HelpOnline_Click" />
                                    <Separator />
                                    <MenuItem Header="ℹ 关于(_A)" Click="HelpAbout_Click" />
                                </MenuItem>
                            </Menu>

                            <ToolBar x:Name="ToolBarPanel" DockPanel.Dock="Top"
                                     Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                <Button Content="📝" ToolTip="新建" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="FileNew_Click" />
                                <Button Content="📂" ToolTip="打开" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="FileOpen_Click" />
                                <Button Content="💾" ToolTip="保存" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="FileSave_Click" />
                                <Separator />
                                <Button Content="↩" ToolTip="撤销" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="EditUndo_Click" />
                                <Button Content="↪" ToolTip="重做" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="EditRedo_Click" />
                                <Separator />
                                <Button Content="🔍" ToolTip="查找" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="EditFind_Click" />
                                <Separator />
                                <Button Content="ℹ" ToolTip="关于" Style="{StaticResource DemoButton}"
                                        Background="Transparent" Foreground="#424242"
                                        Padding="8,4" FontSize="14" Click="HelpAbout_Click" />
                            </ToolBar>

                            <TextBlock DockPanel.Dock="Top" Text="📝 文档编辑区域"
                                       FontSize="18" Foreground="#BDBDBD"
                                       HorizontalAlignment="Center" Margin="0,40" />

                            <TextBox x:Name="TxtContent" DockPanel.Dock="Top"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="180" Margin="8" Padding="8"
                                     BorderBrush="#E0E0E0" BorderThickness="1"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="欢迎使用 Mini 编辑器！&#x0a;&#x0a;这是一个集成了菜单、工具栏和状态栏的简单演示。&#x0a;你可以点击菜单项或工具栏按钮来触发操作。&#x0a;&#x0a;试试看：&#x0a;• 使用「视图」菜单切换工具栏和状态栏的显示&#x0a;• 使用「字体大小」子菜单调整显示" />

                            <StatusBar x:Name="StatusBarPanel" DockPanel.Dock="Bottom"
                                       Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                                <StatusBarItem>
                                    <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#616161" FontSize="12" />
                                </StatusBarItem>
                                <Separator />
                                <StatusBarItem>
                                    <TextBlock x:Name="TxtCharCount2" Text="字符: 0" Foreground="#9E9E9E" FontSize="12" />
                                </StatusBarItem>
                                <Separator />
                                <StatusBarItem HorizontalAlignment="Right">
                                    <TextBlock x:Name="TxtDateTime" Text="" Foreground="#9E9E9E" FontSize="12" />
                                </StatusBarItem>
                            </StatusBar>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. Menu 控件详解" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="关键知识点: MenuItem 支持嵌套（子菜单）、Separator（分隔线）、IsCheckable（可勾选）、InputGestureText（快捷键提示）、Icon（图标）。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="BtnToggleToolbar" Content="切换工具栏" Style="{StaticResource DemoButton}"
                                Background="{StaticResource AccentBrush}" FontSize="12" Padding="8,4"
                                Click="BtnToggleToolbar_Click" />
                        <Button x:Name="BtnToggleStatusbar" Content="切换状态栏" Style="{StaticResource DemoButton}"
                                Background="{StaticResource SecondaryBrush}" FontSize="12" Padding="8,4"
                                Click="BtnToggleStatusbar_Click" />
                    </StackPanel>

                    <Border Background="White" CornerRadius="6" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1">
                        <TextBlock>
                            <Bold>Menu 属性说明:</Bold><LineBreak />
                            • <Bold>Header</Bold>: 菜单项显示的文本，支持 Alt+字母 快捷键（使用 _F 格式）<LineBreak />
                            • <Bold>IsCheckable</Bold>: 设为 True 可让菜单项带有勾选标记<LineBreak />
                            • <Bold>InputGestureText</Bold>: 显示快捷键提示（仅显示，不实际绑定）<LineBreak />
                            • <Bold>Separator</Bold>: 在菜单项之间添加分割线<LineBreak />
                            • <Bold>Icon</Bold>: 在菜单项左侧显示图标
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. 事件日志" Style="{StaticResource SubTitleText}" />
                    <TextBlock x:Name="TxtMenuLog" Text="等待操作..." FontSize="13"
                               Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap"
                               MinHeight="30" />
                    <Button x:Name="BtnClearMenuLog" Content="清空日志" Style="{StaticResource DemoButton}"
                            Background="#9E9E9E" FontSize="12" Padding="8,4"
                            HorizontalAlignment="Left" Margin="0,8,0,0"
                            Click="BtnClearMenuLog_Click" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>