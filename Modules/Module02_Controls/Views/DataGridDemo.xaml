<Page x:Class="LearnXaml.Modules.Module02_Controls.Views.DataGridDemo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LearnXaml.Modules.Module02_Controls.Views"
      Title="DataGrid 数据表格"
      Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📊 DataGrid 数据表格控件" Style="{StaticResource TitleText}" />
            <TextBlock Text="DataGrid 是 WPF 中功能最丰富的表格控件，支持排序、选择、编辑、行详情等。"
                       Foreground="#757575" Margin="0,0,0,20" FontSize="14" />

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="1. AutoGenerateColumns 自动生成列" Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="设置 AutoGenerateColumns=&quot;True&quot; 时，DataGrid 会根据数据源属性自动创建列。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <DataGrid x:Name="DgAuto" AutoGenerateColumns="True"
                              Width="700" Height="180" Margin="0,0,0,5"
                              AlternatingRowBackground="#F5F5F5"
                              IsReadOnly="True" SelectionMode="Single"
                              SelectionChanged="DgAuto_SelectionChanged" />
                    <TextBlock x:Name="TxtDgAutoSelect" Text="点击某行查看详情" FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="2. 手动定义列 (AutoGenerateColumns=False)"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="手动定义列可以精确控制每列的标题、宽度、绑定和样式。支持 DataGridTextColumn、DataGridCheckBoxColumn、DataGridComboBoxColumn。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <DataGrid x:Name="DgManual" AutoGenerateColumns="False"
                              Width="700" Height="220"
                              AlternatingRowBackground="#F3F8FF"
                              CanUserSortColumns="True"
                              SelectionMode="Single"
                              SelectionChanged="DgManual_SelectionChanged"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="商品名称" Binding="{Binding Name}" Width="160" />
                            <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100" />
                            <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat=C}" Width="90" />
                            <DataGridTextColumn Header="库存" Binding="{Binding Stock}" Width="70" />
                            <DataGridCheckBoxColumn Header="在售" Binding="{Binding IsOnSale}" Width="60" />
                            <DataGridTemplateColumn Header="状态指示" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Stock, StringFormat=库存:{0}}"
                                                       FontSize="12" Foreground="#616161" />
                                            <TextBlock Text=" | " FontSize="12" Foreground="#BDBDBD" />
                                            <TextBlock Text="{Binding Price, StringFormat=¥{0}}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource DangerBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="TxtDgManualSelect" Text="点击列标题可排序，点击行查看详情"
                               FontSize="12" Foreground="#9E9E9E" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <TextBlock Text="3. 行选择 (SelectionMode) 与 RowDetailsTemplate"
                               Style="{StaticResource SubTitleText}" />
                    <TextBlock Text="SelectionMode 支持 Single（单选）和 Extended（多选）。RowDetailsTemplate 可以展示行的额外详情。"
                               Foreground="#757575" FontSize="13" Margin="0,0,0,10" />

                    <DataGrid x:Name="DgDetails" AutoGenerateColumns="False"
                              Width="700" Height="280"
                              AlternatingRowBackground="#FFF8F0"
                              SelectionMode="Extended"
                              SelectionChanged="DgDetails_SelectionChanged"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                            <DataGridTextColumn Header="商品名称" Binding="{Binding Name}" Width="150" />
                            <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100" />
                            <DataGridTextColumn Header="价格" Binding="{Binding Price, StringFormat=C}" Width="90" />
                            <DataGridTextColumn Header="库存" Binding="{Binding Stock}" Width="70" />
                            <DataGridCheckBoxColumn Header="在售" Binding="{Binding IsOnSale}" Width="60" />
                        </DataGrid.Columns>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#FFF8E1" Padding="12" CornerRadius="4" Margin="20,3">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" FontSize="13" Margin="0,0,0,5">
                                            <Run Text="📦 商品详情: " />
                                            <Run Text="{Binding Name}" Foreground="{StaticResource PrimaryBrush}" />
                                        </TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="编号" FontSize="11" Foreground="#9E9E9E" />
                                                <TextBlock Text="{Binding Id}" FontSize="14" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="分类" FontSize="11" Foreground="#9E9E9E" />
                                                <TextBlock Text="{Binding Category}" FontSize="14" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="描述" FontSize="11" Foreground="#9E9E9E" />
                                                <TextBlock Text="{Binding Description}" FontSize="13" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="TxtDgDetailsSelect" Text="点击行左侧可展开详情"
                                   FontSize="12" Foreground="{StaticResource PrimaryBrush}" />
                        <Button x:Name="BtnSelectAll" Content="选中库存 > 0 的行"
                                Style="{StaticResource DemoButton}" Background="#78909C"
                                FontSize="11" Padding="8,4" Click="BtnSelectAll_Click"
                                Margin="20,0,0,0" />
                        <Button x:Name="BtnClearSelection" Content="清除选择"
                                Style="{StaticResource DemoButton}" Background="#BDBDBD"
                                FontSize="11" Padding="8,4" Click="BtnClearSelection_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>